#!/usr/bin/env node

import { spawnSync } from "node:child_process";
import {
	copyFileSync,
	existsSync,
	lstatSync,
	mkdirSync,
	readdirSync,
	readFileSync,
	readlinkSync,
	rmSync,
	renameSync,
	symlinkSync,
} from "node:fs";
import { dirname, join } from "node:path";
import { fileURLToPath } from "node:url";
import process from "node:process";

const BIN_DIR = dirname(fileURLToPath(import.meta.url));
const REPO_ROOT = join(BIN_DIR, "..");
const PACKAGE_JSON = JSON.parse(readFileSync(join(REPO_ROOT, "package.json"), "utf-8"));
const RESOLVE_SCRIPT = join(REPO_ROOT, "scripts", "resolve_adapter.mjs");
const INIT_SCRIPT = join(REPO_ROOT, "scripts", "init_adapter.mjs");
const DOCTOR_SCRIPT = join(REPO_ROOT, "scripts", "doctor.mjs");
const VARIANT_RUNNER = join(
	REPO_ROOT,
	"scripts",
	"agent-runtime",
	"run-workbench-executor-variants.mjs",
);
const SCENARIO_PROPOSAL_RUNNER = join(
	REPO_ROOT,
	"scripts",
	"agent-runtime",
	"generate-scenario-proposals.mjs",
);
const SCENARIO_INPUT_BUILDER = join(
	REPO_ROOT,
	"scripts",
	"agent-runtime",
	"build-scenario-proposal-input.mjs",
);
const SCENARIO_TELEMETRY_SUMMARIZER = join(
	REPO_ROOT,
	"scripts",
	"agent-runtime",
	"summarize-scenario-telemetry.mjs",
);
const REPORT_PACKET_BUILDER = join(REPO_ROOT, "scripts", "agent-runtime", "build-report-packet.mjs");
const CLI_INTENT_EVALUATOR = join(REPO_ROOT, "scripts", "agent-runtime", "evaluate-cli-intent.mjs");
const ADAPTER_MODE_EVALUATOR = join(REPO_ROOT, "scripts", "agent-runtime", "evaluate-adapter-mode.mjs");
const EVIDENCE_INPUT_BUILDER = join(REPO_ROOT, "scripts", "agent-runtime", "build-evidence-input.mjs");
const EVIDENCE_BUNDLE_BUILDER = join(REPO_ROOT, "scripts", "agent-runtime", "build-evidence-bundle.mjs");
const COMPARE_WORKTREE_PREPARER = join(
	REPO_ROOT,
	"scripts",
	"agent-runtime",
	"prepare-compare-worktrees.mjs",
);
const WORKSPACE_ARTIFACT_PRUNER = join(
	REPO_ROOT,
	"scripts",
	"agent-runtime",
	"prune-workspace-artifacts.mjs",
);
const WORKSPACE_START = join(
	REPO_ROOT,
	"scripts",
	"agent-runtime",
	"workspace-start.mjs",
);
const REVIEW_PACKET_BUILDER = join(REPO_ROOT, "scripts", "agent-runtime", "build-review-packet.mjs");
const REVIEW_PROMPT_INPUT_BUILDER = join(
	REPO_ROOT,
	"scripts",
	"agent-runtime",
	"build-review-prompt-input.mjs",
);
const REVIEW_PROMPT_RENDERER = join(REPO_ROOT, "scripts", "agent-runtime", "render-review-prompt.mjs");
const OPTIMIZE_INPUT_BUILDER = join(REPO_ROOT, "scripts", "agent-runtime", "build-optimize-input.mjs");
const OPTIMIZE_PROPOSAL_GENERATOR = join(
	REPO_ROOT,
	"scripts",
	"agent-runtime",
	"generate-optimize-proposal.mjs",
);
const REVISION_ARTIFACT_BUILDER = join(
	REPO_ROOT,
	"scripts",
	"agent-runtime",
	"build-revision-artifact.mjs",
);
const CHATBOT_NORMALIZER = join(
	REPO_ROOT,
	"scripts",
	"agent-runtime",
	"normalize-chatbot-proposals.mjs",
);
const CLI_NORMALIZER = join(REPO_ROOT, "scripts", "agent-runtime", "normalize-cli-proposals.mjs");
const SKILL_NORMALIZER = join(REPO_ROOT, "scripts", "agent-runtime", "normalize-skill-proposals.mjs");
const BUNDLED_SKILL_DIR = join(REPO_ROOT, "skills", "cautilus");

function fail(message) {
	process.stderr.write(`${message}\n`);
	process.exit(1);
}

function migrateLegacyClaudeSkillsDir(repoRoot) {
	const claudeSkills = join(repoRoot, ".claude", "skills");
	const agentsSkills = join(repoRoot, ".agents", "skills");
	if (!existsSync(claudeSkills)) {
		return;
	}
	const info = lstatSync(claudeSkills);
	if (!info.isDirectory() || info.isSymbolicLink()) {
		return;
	}
	if (existsSync(agentsSkills)) {
		rmSync(claudeSkills, { recursive: true, force: true });
		return;
	}
	mkdirSync(join(repoRoot, ".agents"), { recursive: true });
	renameSync(claudeSkills, agentsSkills);
	process.stdout.write(`Migrated ${claudeSkills} -> ${agentsSkills}\n`);
}

function ensureClaudeSkillsSymlink(repoRoot) {
	const claudeSkills = join(repoRoot, ".claude", "skills");
	const relativeTarget = "../.agents/skills";
	if (existsSync(claudeSkills)) {
		try {
			if (readlinkSync(claudeSkills) === relativeTarget) {
				return;
			}
		} catch {
			// Non-symlink or unreadable entry falls through to replacement below.
		}
		rmSync(claudeSkills, { recursive: true, force: true });
	}
	mkdirSync(join(repoRoot, ".claude"), { recursive: true });
	symlinkSync(relativeTarget, claudeSkills);
}

function copyDirectory(sourceDir, destinationDir) {
	for (const entry of readdirSync(sourceDir, { withFileTypes: true })) {
		const sourcePath = join(sourceDir, entry.name);
		const destinationPath = join(destinationDir, entry.name);
		if (entry.isDirectory()) {
			mkdirSync(destinationPath, { recursive: true });
			copyDirectory(sourcePath, destinationPath);
			continue;
		}
		copyFileSync(sourcePath, destinationPath);
	}
}

function installBundledSkills(args) {
	const overwrite = args.includes("--overwrite");
	const repoRoot = process.cwd();
	const destinationDir = join(repoRoot, ".agents", "skills", "cautilus");
	const destinationSkill = join(destinationDir, "SKILL.md");

	migrateLegacyClaudeSkillsDir(repoRoot);
	if (existsSync(destinationSkill) && !overwrite) {
		fail(`${destinationSkill} already exists\nhint: use --overwrite to replace existing files`);
	}

	if (overwrite) {
		rmSync(destinationDir, { recursive: true, force: true });
	}
	mkdirSync(destinationDir, { recursive: true });
	copyDirectory(BUNDLED_SKILL_DIR, destinationDir);
	ensureClaudeSkillsSymlink(repoRoot);
	process.stdout.write(`Installed ${destinationDir}\n`);
	process.stdout.write("Installed skill expects `cautilus` to be available on PATH.\n");
}

function usage(exitCode = 0) {
	const text = [
		"Usage:",
		"  cautilus adapter resolve [args]",
		"  cautilus adapter init [args]",
		"  cautilus doctor [args]",
		"  cautilus workspace prepare-compare [args]",
		"  cautilus workspace prune-artifacts [args]",
		"  cautilus workspace start [args]",
		"  cautilus scenario normalize chatbot [args]",
		"  cautilus scenario normalize cli [args]",
		"  cautilus scenario normalize skill [args]",
		"  cautilus scenario summarize-telemetry [args]",
		"  cautilus scenario prepare-input [args]",
		"  cautilus scenario propose [args]",
		"  cautilus evidence prepare-input [args]",
		"  cautilus evidence bundle [args]",
		"  cautilus report build [args]",
		"  cautilus mode evaluate [args]",
		"  cautilus skills install [--overwrite]",
		"  cautilus optimize prepare-input [args]",
		"  cautilus optimize propose [args]",
		"  cautilus optimize build-artifact [args]",
		"  cautilus review prepare-input [args]",
		"  cautilus review build-prompt-input [args]",
		"  cautilus review render-prompt [args]",
		"  cautilus cli evaluate [args]",
		"  cautilus review variants [args]",
		"",
		"Examples:",
		"  cautilus adapter resolve --repo-root .",
		"  cautilus adapter init --repo-root .",
		"  cautilus doctor --repo-root .",
		"  cautilus workspace prepare-compare --repo-root . --baseline-ref origin/main --output-dir /tmp/cautilus-compare",
		"  cautilus workspace prune-artifacts --root /tmp/cautilus-runs --keep-last 20",
		"  eval \"$(cautilus workspace start --label mode-held-out)\"",
		"  cautilus scenario normalize chatbot --input ./fixtures/scenario-proposals/chatbot-input.json",
		"  cautilus scenario normalize cli --input ./fixtures/scenario-proposals/cli-input.json",
		"  cautilus scenario normalize skill --input ./fixtures/scenario-proposals/skill-input.json",
		"  cautilus scenario summarize-telemetry --results ./results.json",
		"  cautilus scenario prepare-input --candidates ./fixtures/scenario-proposals/candidates.json --registry ./fixtures/scenario-proposals/registry.json --coverage ./fixtures/scenario-proposals/coverage.json",
		"  cautilus scenario propose --input ./fixtures/scenario-proposals/standalone-input.json",
		"  cautilus evidence prepare-input --report-file /tmp/cautilus-mode/report.json --scenario-results-file /tmp/cautilus-mode/held_out-scenario-results.json --run-audit-file /tmp/cautilus-run-audit/run-audit-summary.json",
		"  cautilus evidence bundle --input /tmp/cautilus-evidence/input.json",
		"  cautilus report build --input ./fixtures/reports/report-input.json",
		"  cautilus mode evaluate --repo-root . --mode held_out --intent 'CLI behavior should remain legible.' --baseline-ref origin/main --output-dir /tmp/cautilus-mode",
		"  cautilus skills install",
		"  cautilus optimize prepare-input --report-file /tmp/cautilus-mode/report.json --review-summary /tmp/cautilus-review/review-summary.json --history-file /tmp/cautilus-history/scenario-history.snapshot.json --target prompt --optimizer reflection --budget medium",
		"  cautilus optimize propose --input /tmp/cautilus-optimize/input.json",
		"  cautilus optimize build-artifact --proposal-file /tmp/cautilus-optimize/proposal.json",
		"  cautilus review prepare-input --repo-root . --report-file /tmp/cautilus-mode/report.json",
		"  cautilus review build-prompt-input --review-packet /tmp/cautilus-mode/review.json",
		"  cautilus review render-prompt --input /tmp/cautilus-mode/review-prompt-input.json",
		"  cautilus cli evaluate --input ./fixtures/cli-evaluation/doctor-missing-adapter.json",
		"  cautilus review variants --repo-root . --workspace . --output-dir /tmp/cautilus-review",
	].join("\n");
	const out = exitCode === 0 ? process.stdout : process.stderr;
	out.write(`${text}\n`);
	process.exit(exitCode);
}

function run(command, args) {
	const result = spawnSync(command, args, {
		cwd: process.cwd(),
		stdio: "inherit",
	});
	process.exit(result.status ?? 1);
}

const [, , area, action, ...rest] = process.argv;

if (area === "--version" || area === "-v" || area === "version") {
	process.stdout.write(`${PACKAGE_JSON.version}\n`);
	process.exit(0);
}

if (!area || area === "-h" || area === "--help") {
	usage(0);
}

if (area === "adapter" && action === "resolve") {
	run("node", [RESOLVE_SCRIPT, ...rest]);
}

if (area === "adapter" && action === "init") {
	run("node", [INIT_SCRIPT, ...rest]);
}

if (area === "doctor") {
	run("node", [DOCTOR_SCRIPT, action, ...rest].filter(Boolean));
}

if (area === "workspace" && action === "prepare-compare") {
	run("node", [COMPARE_WORKTREE_PREPARER, ...rest]);
}

if (area === "workspace" && action === "prune-artifacts") {
	run("node", [WORKSPACE_ARTIFACT_PRUNER, ...rest]);
}

if (area === "workspace" && action === "start") {
	run("node", [WORKSPACE_START, ...rest]);
}

if (area === "scenario" && action === "propose") {
	run("node", [SCENARIO_PROPOSAL_RUNNER, ...rest]);
}

if (area === "scenario" && action === "normalize" && rest[0] === "chatbot") {
	run("node", [CHATBOT_NORMALIZER, ...rest.slice(1)]);
}

if (area === "scenario" && action === "normalize" && rest[0] === "cli") {
	run("node", [CLI_NORMALIZER, ...rest.slice(1)]);
}

if (area === "scenario" && action === "normalize" && rest[0] === "skill") {
	run("node", [SKILL_NORMALIZER, ...rest.slice(1)]);
}

if (area === "scenario" && action === "prepare-input") {
	run("node", [SCENARIO_INPUT_BUILDER, ...rest]);
}

if (area === "scenario" && action === "summarize-telemetry") {
	run("node", [SCENARIO_TELEMETRY_SUMMARIZER, ...rest]);
}

if (area === "evidence" && action === "prepare-input") {
	run("node", [EVIDENCE_INPUT_BUILDER, ...rest]);
}

if (area === "evidence" && action === "bundle") {
	run("node", [EVIDENCE_BUNDLE_BUILDER, ...rest]);
}

if (area === "report" && action === "build") {
	run("node", [REPORT_PACKET_BUILDER, ...rest]);
}

if (area === "mode" && action === "evaluate") {
	run("node", [ADAPTER_MODE_EVALUATOR, ...rest]);
}

if (area === "skills" && action === "install") {
	installBundledSkills(rest);
	process.exit(0);
}

if (area === "optimize" && action === "prepare-input") {
	run("node", [OPTIMIZE_INPUT_BUILDER, ...rest]);
}

if (area === "optimize" && action === "propose") {
	run("node", [OPTIMIZE_PROPOSAL_GENERATOR, ...rest]);
}

if (area === "optimize" && action === "build-artifact") {
	run("node", [REVISION_ARTIFACT_BUILDER, ...rest]);
}

if (area === "review" && action === "prepare-input") {
	run("node", [REVIEW_PACKET_BUILDER, ...rest]);
}

if (area === "review" && action === "build-prompt-input") {
	run("node", [REVIEW_PROMPT_INPUT_BUILDER, ...rest]);
}

if (area === "review" && action === "render-prompt") {
	run("node", [REVIEW_PROMPT_RENDERER, ...rest]);
}

if (area === "cli" && action === "evaluate") {
	run("node", [CLI_INTENT_EVALUATOR, ...rest]);
}

if (area === "review" && action === "variants") {
	run("node", [VARIANT_RUNNER, ...rest]);
}

usage(1);
