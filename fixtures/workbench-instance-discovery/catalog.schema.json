{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cautilus.workbench_instance_catalog.v1",
  "type": "object",
  "required": ["schemaVersion", "instances"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "cautilus.workbench_instance_catalog.v1"
    },
    "generatedAt": {
      "type": "string"
    },
    "instances": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["instanceId", "displayLabel"],
        "properties": {
          "instanceId": {
            "type": "string"
          },
          "displayLabel": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "dataRoot": {
            "type": "string"
          },
          "paths": {
            "type": "object",
            "properties": {
              "scenarioStore": {
                "type": "string"
              },
              "conversationSummaries": {
                "type": "string"
              },
              "conversationTranscripts": {
                "type": "string"
              },
              "proposalCandidates": {
                "type": "string"
              },
              "scenarioResults": {
                "type": "string"
              },
              "runArtifacts": {
                "type": "string"
              },
              "compareArtifacts": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
