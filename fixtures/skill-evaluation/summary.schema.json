{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cautilus.skill_evaluation_summary.v1",
  "type": "object",
  "required": [
    "schemaVersion",
    "skillId",
    "skillDisplayName",
    "evaluatedAt",
    "recommendation",
    "evaluationCounts",
    "evaluations",
    "evaluationRuns"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "cautilus.skill_evaluation_summary.v1"
    },
    "skillId": {
      "type": "string"
    },
    "skillDisplayName": {
      "type": "string"
    },
    "evaluatedAt": {
      "type": "string"
    },
    "recommendation": {
      "type": "string",
      "enum": ["accept-now", "defer", "reject"]
    },
    "evaluationCounts": {
      "type": "object",
      "required": ["total", "passed", "failed", "degraded", "blocked", "trigger", "execution"],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "degraded": { "type": "integer", "minimum": 0 },
        "blocked": { "type": "integer", "minimum": 0 },
        "trigger": { "type": "integer", "minimum": 0 },
        "execution": { "type": "integer", "minimum": 0 },
        "unstable": { "type": "integer", "minimum": 0 }
      }
    },
    "samplingSummary": {
      "type": "object",
      "properties": {
        "evaluationsWithSampling": { "type": "integer", "minimum": 0 },
        "unstableEvaluations": { "type": "integer", "minimum": 0 },
        "totalSamples": { "type": "integer", "minimum": 0 },
        "totalConsensusSamples": { "type": "integer", "minimum": 0 },
        "totalInvocations": { "type": "integer", "minimum": 0 },
        "totalPassingSamples": { "type": "integer", "minimum": 0 },
        "overallPassRate": { "type": "number", "minimum": 0 },
        "overallInvocationRate": { "type": "number", "minimum": 0 },
        "overallConsensusRate": { "type": "number", "minimum": 0 }
      }
    },
    "comparisonSummary": {
      "type": "object",
      "properties": {
        "evaluationsWithBaseline": { "type": "integer", "minimum": 0 },
        "betterThanBaseline": { "type": "integer", "minimum": 0 },
        "sameAsBaseline": { "type": "integer", "minimum": 0 },
        "worseThanBaseline": { "type": "integer", "minimum": 0 }
      }
    },
    "evaluations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "evaluationId",
          "targetKind",
          "targetId",
          "displayName",
          "evaluationKind",
          "surface",
          "status",
          "startedAt",
          "prompt",
          "summary",
          "invoked",
          "intentProfile"
        ],
        "properties": {
          "evaluationId": { "type": "string" },
          "targetKind": { "type": "string" },
          "targetId": { "type": "string" },
          "displayName": { "type": "string" },
          "evaluationKind": { "type": "string", "enum": ["trigger", "execution"] },
          "surface": { "type": "string", "enum": ["trigger_selection", "execution_quality"] },
          "status": { "type": "string", "enum": ["passed", "failed", "degraded", "blocked"] },
          "startedAt": { "type": "string" },
          "prompt": { "type": "string" },
          "summary": { "type": "string" },
          "invoked": { "type": "boolean" },
          "expectedTrigger": { "type": "string" },
          "blockerKind": { "type": "string" },
          "metrics": {
            "type": "object",
            "properties": {
              "total_tokens": { "type": "number", "minimum": 0 },
              "duration_ms": { "type": "number", "minimum": 0 },
              "cost_usd": { "type": "number", "minimum": 0 }
            }
          },
          "telemetry": {
            "type": "object",
            "properties": {
              "provider": { "type": "string" },
              "model": { "type": "string" },
              "prompt_tokens": { "type": "number", "minimum": 0 },
              "completion_tokens": { "type": "number", "minimum": 0 },
              "total_tokens": { "type": "number", "minimum": 0 },
              "cost_usd": { "type": "number", "minimum": 0 }
            }
          },
          "sampling": {
            "type": "object",
            "properties": {
              "sampleCount": { "type": "integer", "minimum": 1 },
              "consensusCount": { "type": "integer", "minimum": 0 },
              "passCount": { "type": "integer", "minimum": 0 },
              "invokedCount": { "type": "integer", "minimum": 0 },
              "passRate": { "type": "number", "minimum": 0 },
              "invocationRate": { "type": "number", "minimum": 0 },
              "consensusRate": { "type": "number", "minimum": 0 },
              "stable": { "type": "boolean" },
              "unstable": { "type": "boolean" }
            }
          },
          "thresholds": {
            "type": "object",
            "properties": {
              "max_total_tokens": { "type": "number", "minimum": 0 },
              "max_duration_ms": { "type": "number", "minimum": 0 },
              "max_cost_usd": { "type": "number", "minimum": 0 }
            }
          },
          "thresholdFindings": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["metric", "actual", "limit"],
              "properties": {
                "metric": { "type": "string" },
                "actual": { "type": "number", "minimum": 0 },
                "limit": { "type": "number", "minimum": 0 }
              }
            }
          },
          "artifactRefs": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["kind", "path"],
              "properties": {
                "kind": { "type": "string" },
                "path": { "type": "string" }
              }
            }
          },
          "baselineComparison": {
            "type": "object",
            "properties": {
              "baselineStatus": { "type": "string", "enum": ["passed", "failed", "degraded", "blocked"] },
              "relativeStatus": { "type": "string", "enum": ["better", "same", "worse"] },
              "baselineInvoked": { "type": "boolean" },
              "baselineOutcome": { "type": "string", "enum": ["passed", "failed", "degraded", "blocked"] },
              "metricDeltas": {
                "type": "object",
                "properties": {
                  "duration_ms": { "type": "number" },
                  "total_tokens": { "type": "number" },
                  "cost_usd": { "type": "number" }
                }
              }
            }
          },
          "intentProfile": {
            "type": "object",
            "required": ["schemaVersion", "intentId", "summary", "behaviorSurface", "successDimensions", "guardrailDimensions"],
            "properties": {
              "schemaVersion": { "type": "string", "const": "cautilus.behavior_intent.v1" },
              "intentId": { "type": "string" },
              "summary": { "type": "string" },
              "behaviorSurface": { "type": "string" },
              "successDimensions": { "type": "array", "minItems": 1, "items": { "type": "object" } },
              "guardrailDimensions": { "type": "array", "items": { "type": "object" } }
            }
          }
        }
      }
    },
    "evaluationRuns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "targetKind",
          "targetId",
          "displayName",
          "evaluationKind",
          "surface",
          "startedAt",
          "status",
          "summary",
          "intentProfile"
        ],
        "properties": {
          "targetKind": { "type": "string" },
          "targetId": { "type": "string" },
          "displayName": { "type": "string" },
          "evaluationKind": { "type": "string", "enum": ["trigger", "execution"] },
          "surface": { "type": "string", "enum": ["trigger_selection", "execution_quality"] },
          "startedAt": { "type": "string" },
          "status": { "type": "string", "enum": ["passed", "failed", "degraded", "blocked"] },
          "summary": { "type": "string" },
          "blockerKind": { "type": "string" },
          "metrics": {
            "type": "object",
            "properties": {
              "total_tokens": { "type": "number", "minimum": 0 },
              "duration_ms": { "type": "number", "minimum": 0 },
              "cost_usd": { "type": "number", "minimum": 0 }
            }
          },
          "telemetry": {
            "type": "object",
            "properties": {
              "provider": { "type": "string" },
              "model": { "type": "string" },
              "prompt_tokens": { "type": "number", "minimum": 0 },
              "completion_tokens": { "type": "number", "minimum": 0 },
              "total_tokens": { "type": "number", "minimum": 0 },
              "cost_usd": { "type": "number", "minimum": 0 }
            }
          },
          "sampling": {
            "type": "object",
            "properties": {
              "sampleCount": { "type": "integer", "minimum": 1 },
              "consensusCount": { "type": "integer", "minimum": 0 },
              "passCount": { "type": "integer", "minimum": 0 },
              "invokedCount": { "type": "integer", "minimum": 0 },
              "passRate": { "type": "number", "minimum": 0 },
              "invocationRate": { "type": "number", "minimum": 0 },
              "consensusRate": { "type": "number", "minimum": 0 },
              "stable": { "type": "boolean" },
              "unstable": { "type": "boolean" }
            }
          },
          "artifactRefs": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["kind", "path"],
              "properties": {
                "kind": { "type": "string" },
                "path": { "type": "string" }
              }
            }
          },
          "baselineComparison": {
            "type": "object",
            "properties": {
              "baselineStatus": { "type": "string", "enum": ["passed", "failed", "degraded", "blocked"] },
              "relativeStatus": { "type": "string", "enum": ["better", "same", "worse"] },
              "baselineInvoked": { "type": "boolean" },
              "baselineOutcome": { "type": "string", "enum": ["passed", "failed", "degraded", "blocked"] },
              "metricDeltas": {
                "type": "object",
                "properties": {
                  "duration_ms": { "type": "number" },
                  "total_tokens": { "type": "number" },
                  "cost_usd": { "type": "number" }
                }
              }
            }
          },
          "intentProfile": {
            "type": "object",
            "required": ["schemaVersion", "intentId", "summary", "behaviorSurface", "successDimensions", "guardrailDimensions"],
            "properties": {
              "schemaVersion": { "type": "string", "const": "cautilus.behavior_intent.v1" },
              "intentId": { "type": "string" },
              "summary": { "type": "string" },
              "behaviorSurface": { "type": "string" },
              "successDimensions": { "type": "array", "minItems": 1, "items": { "type": "object" } },
              "guardrailDimensions": { "type": "array", "items": { "type": "object" } }
            }
          }
        }
      }
    }
  }
}
