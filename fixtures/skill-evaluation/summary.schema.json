{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cautilus.skill_evaluation_summary.v1",
  "type": "object",
  "required": [
    "schemaVersion",
    "skillId",
    "skillDisplayName",
    "evaluatedAt",
    "recommendation",
    "evaluationCounts",
    "evaluations",
    "evaluationRuns"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "cautilus.skill_evaluation_summary.v1"
    },
    "skillId": {
      "type": "string"
    },
    "skillDisplayName": {
      "type": "string"
    },
    "evaluatedAt": {
      "type": "string"
    },
    "recommendation": {
      "type": "string",
      "enum": ["accept-now", "defer", "reject"]
    },
    "evaluationCounts": {
      "type": "object",
      "required": ["total", "passed", "failed", "degraded", "blocked", "trigger", "execution"],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "degraded": { "type": "integer", "minimum": 0 },
        "blocked": { "type": "integer", "minimum": 0 },
        "trigger": { "type": "integer", "minimum": 0 },
        "execution": { "type": "integer", "minimum": 0 }
      }
    },
    "evaluations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "evaluationId",
          "targetKind",
          "targetId",
          "displayName",
          "evaluationKind",
          "surface",
          "status",
          "startedAt",
          "prompt",
          "summary",
          "invoked",
          "intentProfile"
        ],
        "properties": {
          "evaluationId": { "type": "string" },
          "targetKind": { "type": "string" },
          "targetId": { "type": "string" },
          "displayName": { "type": "string" },
          "evaluationKind": { "type": "string", "enum": ["trigger", "execution"] },
          "surface": { "type": "string", "enum": ["trigger_selection", "execution_quality"] },
          "status": { "type": "string", "enum": ["passed", "failed", "degraded", "blocked"] },
          "startedAt": { "type": "string" },
          "prompt": { "type": "string" },
          "summary": { "type": "string" },
          "invoked": { "type": "boolean" },
          "expectedTrigger": { "type": "string" },
          "intentProfile": {
            "type": "object",
            "required": ["schemaVersion", "intentId", "summary", "behaviorSurface", "successDimensions", "guardrailDimensions"],
            "properties": {
              "schemaVersion": { "type": "string", "const": "cautilus.behavior_intent.v1" },
              "intentId": { "type": "string" },
              "summary": { "type": "string" },
              "behaviorSurface": { "type": "string" },
              "successDimensions": { "type": "array", "minItems": 1, "items": { "type": "object" } },
              "guardrailDimensions": { "type": "array", "items": { "type": "object" } }
            }
          }
        }
      }
    },
    "evaluationRuns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "targetKind",
          "targetId",
          "displayName",
          "evaluationKind",
          "surface",
          "startedAt",
          "status",
          "summary",
          "intentProfile"
        ],
        "properties": {
          "targetKind": { "type": "string" },
          "targetId": { "type": "string" },
          "displayName": { "type": "string" },
          "evaluationKind": { "type": "string", "enum": ["trigger", "execution"] },
          "surface": { "type": "string", "enum": ["trigger_selection", "execution_quality"] },
          "startedAt": { "type": "string" },
          "status": { "type": "string", "enum": ["passed", "failed", "degraded", "blocked"] },
          "summary": { "type": "string" },
          "intentProfile": {
            "type": "object",
            "required": ["schemaVersion", "intentId", "summary", "behaviorSurface", "successDimensions", "guardrailDimensions"],
            "properties": {
              "schemaVersion": { "type": "string", "const": "cautilus.behavior_intent.v1" },
              "intentId": { "type": "string" },
              "summary": { "type": "string" },
              "behaviorSurface": { "type": "string" },
              "successDimensions": { "type": "array", "minItems": 1, "items": { "type": "object" } },
              "guardrailDimensions": { "type": "array", "items": { "type": "object" } }
            }
          }
        }
      }
    }
  }
}
