{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cautilus.optimize_inputs.v1",
  "title": "Cautilus Optimize Inputs",
  "type": "object",
  "required": [
    "schemaVersion",
    "generatedAt",
    "repoRoot",
    "optimizationTarget",
    "intentProfile",
    "optimizer",
    "reportFile",
    "report",
    "objective"
  ],
  "properties": {
    "schemaVersion": {
      "const": "cautilus.optimize_inputs.v1"
    },
    "generatedAt": {
      "type": "string"
    },
    "repoRoot": {
      "type": "string"
    },
    "optimizationTarget": {
      "type": "string",
      "enum": [
        "prompt",
        "adapter"
      ]
    },
    "intentProfile": {
      "type": "object"
    },
    "optimizer": {
      "type": "object",
      "required": [
        "kind",
        "budget",
        "plan"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "repair",
            "reflection",
            "history_followup"
          ]
        },
        "budget": {
          "type": "string",
          "enum": [
            "light",
            "medium",
            "heavy"
          ]
        },
        "plan": {
          "type": "object",
          "required": [
            "evidenceLimit",
            "suggestedChangeLimit",
            "reviewVariantLimit",
            "historySignalLimit"
          ],
          "properties": {
            "evidenceLimit": {
              "type": "integer"
            },
            "suggestedChangeLimit": {
              "type": "integer"
            },
            "reviewVariantLimit": {
              "type": "integer"
            },
            "historySignalLimit": {
              "type": "integer"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "targetFile": {
      "type": "object",
      "required": [
        "path",
        "exists"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "exists": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "reportFile": {
      "type": "string"
    },
    "report": {
      "type": "object"
    },
    "reviewSummaryFile": {
      "type": "string"
    },
    "reviewSummary": {
      "type": "object"
    },
    "scenarioHistoryFile": {
      "type": "string"
    },
    "scenarioHistory": {
      "type": "object"
    },
    "objective": {
      "type": "object",
      "required": [
        "summary",
        "constraints"
      ],
      "properties": {
        "summary": {
          "type": "string"
        },
        "constraints": {
          "type": "array"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
