      "type": "object"
    },
    "searchConfigSources": {
      "type": "object"
    },
    "mutationConfig": {
      "type": "object"
    },
    "mutationEvidencePolicy": {
      "type": "object"
    },
    "scenarioSets": {
      "type": "object"
    },
    "evaluationFiles": {
      "type": "object"
    },
    "evaluationContext": {
      "type": "object"
    },
    "objective": {
      "type": "object"
    }
