{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cautilus.instruction_surface_cases.v1",
  "type": "object",
  "required": ["schemaVersion", "suiteId", "evaluations"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "cautilus.instruction_surface_cases.v1"
    },
    "suiteId": {
      "type": "string"
    },
    "suiteDisplayName": {
      "type": "string"
    },
    "evaluations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["evaluationId", "prompt"],
        "properties": {
          "evaluationId": { "type": "string" },
          "displayName": { "type": "string" },
          "prompt": { "type": "string" },
          "taskPath": { "type": "string" },
          "instructionSurface": {
            "type": "object",
            "required": ["files"],
            "properties": {
              "surfaceLabel": { "type": "string" },
              "files": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["path"],
                  "properties": {
                    "path": { "type": "string" },
                    "kind": { "type": "string", "enum": ["file", "symlink"] },
                    "content": { "type": "string" },
                    "sourceFile": { "type": "string" },
                    "targetPath": { "type": "string" }
                  }
                }
              }
            }
          },
          "expectedEntryFile": { "type": "string" },
          "requiredInstructionFiles": {
            "type": "array",
            "items": { "type": "string" }
          },
          "forbiddenInstructionFiles": {
            "type": "array",
            "items": { "type": "string" }
          },
          "requiredSupportingFiles": {
            "type": "array",
            "items": { "type": "string" }
          },
          "forbiddenSupportingFiles": {
            "type": "array",
            "items": { "type": "string" }
          },
          "expectedRouting": {
            "type": "object",
            "properties": {
              "selectedSkill": { "type": "string" },
              "bootstrapHelper": { "type": "string" },
              "workSkill": { "type": "string" },
              "selectedSupport": { "type": "string" },
              "firstToolCallPattern": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
