{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cautilus.instruction_surface_inputs.v1",
  "type": "object",
  "required": ["schemaVersion", "suiteId", "evaluations"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "cautilus.instruction_surface_inputs.v1"
    },
    "suiteId": {
      "type": "string"
    },
    "suiteDisplayName": {
      "type": "string"
    },
    "evaluations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "evaluationId",
          "prompt",
          "startedAt",
          "observationStatus",
          "summary",
          "loadedInstructionFiles",
          "loadedSupportingFiles",
          "routingDecision",
          "instructionSurface",
          "artifactRefs"
        ],
        "properties": {
          "evaluationId": { "type": "string" },
          "displayName": { "type": "string" },
          "prompt": { "type": "string" },
          "taskPath": { "type": "string" },
          "startedAt": { "type": "string" },
          "observationStatus": {
            "type": "string",
            "enum": ["observed", "blocked"]
          },
          "summary": { "type": "string" },
          "entryFile": { "type": "string" },
          "loadedInstructionFiles": {
            "type": "array",
            "items": { "type": "string" }
          },
          "loadedSupportingFiles": {
            "type": "array",
            "items": { "type": "string" }
          },
          "routingDecision": {
            "type": "object",
            "properties": {
              "selectedSkill": { "type": "string" },
              "bootstrapHelper": { "type": "string" },
              "workSkill": { "type": "string" },
              "selectedSupport": { "type": "string" },
              "firstToolCall": { "type": "string" },
              "reasonSummary": { "type": "string" }
            }
          },
          "instructionSurface": {
            "type": "object",
            "required": ["surfaceLabel", "files"],
            "properties": {
              "surfaceLabel": { "type": "string" },
              "files": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["path", "kind", "sourceKind"],
                  "properties": {
                    "path": { "type": "string" },
                    "kind": { "type": "string" },
                    "sourceKind": { "type": "string" },
                    "sourceFile": { "type": "string" },
                    "targetPath": { "type": "string" },
                    "artifactPath": { "type": "string" }
                  }
                }
              }
            }
          },
          "expectedEntryFile": { "type": "string" },
          "requiredInstructionFiles": {
            "type": "array",
            "items": { "type": "string" }
          },
          "forbiddenInstructionFiles": {
            "type": "array",
            "items": { "type": "string" }
          },
          "requiredSupportingFiles": {
            "type": "array",
            "items": { "type": "string" }
          },
          "forbiddenSupportingFiles": {
            "type": "array",
            "items": { "type": "string" }
          },
          "expectedRouting": {
            "type": "object",
            "properties": {
              "selectedSkill": { "type": "string" },
              "bootstrapHelper": { "type": "string" },
              "workSkill": { "type": "string" },
              "selectedSupport": { "type": "string" },
              "firstToolCallPattern": { "type": "string" }
            }
          },
          "blockerKind": { "type": "string" },
          "telemetry": {
            "type": "object",
            "properties": {
              "provider": { "type": "string" },
              "model": { "type": "string" },
              "prompt_tokens": { "type": "number", "minimum": 0 },
              "completion_tokens": { "type": "number", "minimum": 0 },
              "total_tokens": { "type": "number", "minimum": 0 },
              "cost_usd": { "type": "number", "minimum": 0 }
            }
          },
          "artifactRefs": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["kind", "path"],
              "properties": {
                "kind": { "type": "string" },
                "path": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
