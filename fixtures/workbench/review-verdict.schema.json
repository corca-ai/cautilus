{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "verdict",
    "summary",
    "findings"
  ],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": [
        "blocker",
        "concern",
        "pass"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "telemetry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "prompt_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "completion_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "total_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "cost_usd": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "severity",
          "message",
          "path"
        ],
        "properties": {
          "severity": {
            "type": "string",
            "enum": [
              "blocker",
              "concern",
              "pass"
            ]
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string"
          }
        }
      }
    }
  }
}
