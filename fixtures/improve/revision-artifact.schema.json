{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cautilus.revision_artifact.v1",
  "title": "Cautilus Revision Artifact",
  "type": "object",
  "required": [
    "schemaVersion",
    "generatedAt",
    "proposalFile",
    "proposal",
    "improveInputFile",
    "repoRoot",
    "improvementTarget",
    "intentProfile",
    "improver",
    "objective",
    "sourceFiles",
    "reportContext",
    "decision",
    "reportRecommendation",
    "revisionBrief",
    "prioritizedEvidence",
    "suggestedChanges",
    "stopConditions",
    "followUpChecks",
    "trialTelemetry"
  ],
  "properties": {
    "schemaVersion": {
      "const": "cautilus.revision_artifact.v1"
    },
    "generatedAt": {
      "type": "string"
    },
    "proposalFile": {
      "type": "string"
    },
    "proposal": {
      "type": "object"
    },
    "improveInputFile": {
      "type": "string"
    },
    "repoRoot": {
      "type": "string"
    },
    "improvementTarget": {
      "type": "string",
      "enum": [
        "prompt",
        "adapter"
      ]
    },
    "intentProfile": {
      "type": "object"
    },
    "improver": {
      "type": "object"
    },
    "objective": {
      "type": "object"
    },
    "targetFile": {
      "type": "object"
    },
    "targetSnapshot": {
      "type": "object"
    },
    "sourceFiles": {
      "type": "object"
    },
    "reportContext": {
      "type": "object"
    },
    "decision": {
      "type": "string",
      "enum": [
        "hold",
        "revise",
        "investigate"
      ]
    },
    "reportRecommendation": {
      "type": "string"
    },
    "revisionBrief": {
      "type": "string"
    },
    "prioritizedEvidence": {
      "type": "array"
    },
    "suggestedChanges": {
      "type": "array"
    },
    "stopConditions": {
      "type": "array"
    },
    "followUpChecks": {
      "type": "array"
    },
    "trialTelemetry": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
