{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cautilus.live_run_simulator_request.v1",
  "type": "object",
  "required": ["schemaVersion", "requestId", "instanceId", "scenarioId", "turnIndex", "maxTurns", "instructions", "transcript"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "cautilus.live_run_simulator_request.v1"
    },
    "requestId": {
      "type": "string"
    },
    "instanceId": {
      "type": "string"
    },
    "scenarioId": {
      "type": "string"
    },
    "turnIndex": {
      "type": "integer",
      "minimum": 1
    },
    "maxTurns": {
      "type": "integer",
      "minimum": 1
    },
    "instructions": {
      "type": "string"
    },
    "consumerMetadata": {
      "type": "object"
    },
    "transcript": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["turnIndex", "simulatorTurn", "assistantTurn"],
        "properties": {
          "turnIndex": {
            "type": "integer",
            "minimum": 1
          },
          "simulatorTurn": {
            "type": "object",
            "required": ["text"],
            "properties": {
              "text": {
                "type": "string"
              }
            }
          },
          "assistantTurn": {
            "type": "object",
            "required": ["text"],
            "properties": {
              "text": {
                "type": "string"
              }
            }
          },
          "consumerSignal": {
            "type": "object"
          }
        }
      }
    }
  }
}
