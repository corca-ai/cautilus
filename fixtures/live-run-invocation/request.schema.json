{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cautilus.live_run_invocation_request.v1",
  "type": "object",
  "required": ["schemaVersion", "requestId", "instanceId", "scenario", "timeoutMs"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "cautilus.live_run_invocation_request.v1"
    },
    "requestId": {
      "type": "string"
    },
    "instanceId": {
      "type": "string"
    },
    "timeoutMs": {
      "type": "integer",
      "minimum": 1
    },
    "captureTranscript": {
      "type": "boolean"
    },
    "operatorNote": {
      "type": "string"
    },
    "scenario": {
      "type": "object",
      "required": ["scenarioId", "name", "description", "maxTurns", "sideEffectsMode", "simulatorTurns"],
      "properties": {
        "scenarioId": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "maxTurns": {
          "type": "integer",
          "minimum": 1
        },
        "sideEffectsMode": {
          "type": "string"
        },
        "simulatorTurns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "intentProfile": {
          "type": "object"
        }
      }
    }
  }
}
