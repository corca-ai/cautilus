{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cautilus.live_run_invocation_batch_prepare_input.v1",
  "type": "object",
  "required": ["schemaVersion", "instanceId", "timeoutMs", "samplesPerScenario", "scenarios"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "cautilus.live_run_invocation_batch_prepare_input.v1"
    },
    "instanceId": {
      "type": "string"
    },
    "timeoutMs": {
      "type": "integer",
      "minimum": 1
    },
    "samplesPerScenario": {
      "type": "integer",
      "minimum": 1
    },
    "requestIdPrefix": {
      "type": "string"
    },
    "captureTranscript": {
      "type": "boolean"
    },
    "consumerMetadata": {
      "type": "object"
    },
    "operatorNote": {
      "type": "string"
    },
    "scenarioIds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["schemaVersion", "scenarioId", "name", "description", "maxTurns", "sideEffectsMode"],
        "properties": {
          "schemaVersion": {
            "type": "string",
            "const": "cautilus.scenario.v1"
          },
          "scenarioId": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "brief": {
            "type": "string"
          },
          "maxTurns": {
            "type": "number",
            "minimum": 1
          },
          "sideEffectsMode": {
            "type": "string"
          },
          "simulator": {
            "type": "object",
            "required": ["kind"],
            "properties": {
              "kind": {
                "type": "string"
              },
              "turns": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["text"],
                  "properties": {
                    "text": {
                      "type": "string"
                    },
                    "metadata": {
                      "type": "object"
                    }
                  }
                }
              },
              "instructions": {
                "type": "string"
              },
              "seedTurns": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["text"],
                  "properties": {
                    "text": {
                      "type": "string"
                    },
                    "metadata": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          },
          "intentProfile": {
            "type": "object"
          }
        }
      }
    }
  }
}
