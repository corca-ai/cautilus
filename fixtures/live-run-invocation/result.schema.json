{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cautilus.live_run_invocation_result.v1",
  "type": "object",
  "required": ["schemaVersion", "requestId", "instanceId", "executionStatus", "summary"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "cautilus.live_run_invocation_result.v1"
    },
    "requestId": {
      "type": "string"
    },
    "instanceId": {
      "type": "string"
    },
    "executionStatus": {
      "type": "string",
      "enum": ["completed", "blocked", "failed"]
    },
    "summary": {
      "type": "string"
    },
    "stopReason": {
      "type": "string"
    },
    "startedAt": {
      "type": "string"
    },
    "completedAt": {
      "type": "string"
    },
    "durationMs": {
      "type": "integer",
      "minimum": 0
    },
    "scenarioResult": {
      "type": "object",
      "required": ["scenarioId", "status", "summary"],
      "properties": {
        "scenarioId": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "evaluation": {
          "type": "object",
          "required": ["schemaVersion", "status", "summary"],
          "properties": {
            "schemaVersion": {
              "type": "string",
              "const": "cautilus.live_run_evaluator_result.v1"
            },
            "status": {
              "type": "string",
              "enum": ["passed", "failed", "error"]
            },
            "overallScore": {
              "type": "number"
            },
            "summary": {
              "type": "string"
            },
            "details": {
              "type": "object"
            }
          }
        },
        "transcriptExcerpt": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["turnIndex", "simulatorTurn", "assistantTurn"],
            "properties": {
              "turnIndex": {
                "type": "integer",
                "minimum": 1
              },
              "simulatorTurn": {
                "type": "object",
                "required": ["text"],
                "properties": {
                  "text": {
                    "type": "string"
                  }
                }
              },
              "assistantTurn": {
                "type": "object",
                "required": ["text"],
                "properties": {
                  "text": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "transcript": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["turnIndex", "simulatorTurn", "assistantTurn"],
        "properties": {
          "turnIndex": {
            "type": "integer",
            "minimum": 1
          },
          "simulatorTurn": {
            "type": "object",
            "required": ["text"],
            "properties": {
              "text": {
                "type": "string"
              }
            }
          },
          "assistantTurn": {
            "type": "object",
            "required": ["text"],
            "properties": {
              "text": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "severity", "message"],
        "properties": {
          "code": {
            "type": "string"
          },
          "severity": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "transientFailure": {
      "type": "object",
      "required": ["class"],
      "properties": {
        "class": {
          "type": "string",
          "enum": ["rate_limit", "transient_provider_failure"]
        },
        "details": {
          "type": "object"
        }
      }
    },
    "artifactPaths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
