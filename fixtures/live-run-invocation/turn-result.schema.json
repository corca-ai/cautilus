{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cautilus.live_run_turn_result.v1",
  "type": "object",
  "required": ["schemaVersion", "requestId", "instanceId", "turnIndex", "executionStatus", "summary"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "cautilus.live_run_turn_result.v1"
    },
    "requestId": {
      "type": "string"
    },
    "instanceId": {
      "type": "string"
    },
    "turnIndex": {
      "type": "integer",
      "minimum": 1
    },
    "executionStatus": {
      "type": "string",
      "enum": ["completed", "blocked", "failed"]
    },
    "summary": {
      "type": "string"
    },
    "assistantTurn": {
      "type": "object",
      "required": ["text"],
      "properties": {
        "text": {
          "type": "string"
        },
        "metadata": {
          "type": "object"
        }
      }
    },
    "consumerSignal": {
      "type": "object"
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "severity", "message"],
        "properties": {
          "code": {
            "type": "string"
          },
          "severity": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  }
}
