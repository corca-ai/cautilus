{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cautilus.live_run_invocation_batch_prepare_catalog_input.v1",
  "type": "object",
  "required": ["schemaVersion", "instanceId", "timeoutMs", "samplesPerScenario", "scenarioCandidates"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "cautilus.live_run_invocation_batch_prepare_catalog_input.v1"
    },
    "instanceId": {
      "type": "string"
    },
    "timeoutMs": {
      "type": "integer",
      "minimum": 1
    },
    "samplesPerScenario": {
      "type": "integer",
      "minimum": 1
    },
    "requestIdPrefix": {
      "type": "string"
    },
    "captureTranscript": {
      "type": "boolean"
    },
    "consumerMetadata": {
      "type": "object"
    },
    "operatorNote": {
      "type": "string"
    },
    "retryPolicy": {
      "type": "object",
      "required": ["maxAttempts", "retryOnClasses"],
      "properties": {
        "maxAttempts": {
          "type": "integer",
          "minimum": 1
        },
        "retryOnClasses": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["rate_limit", "transient_provider_failure"]
          }
        }
      }
    },
    "scenarioIds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "requiredTags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "scenarioCandidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["scenarioId", "name", "description", "maxTurns", "sideEffectsMode"],
        "properties": {
          "scenarioId": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "maxTurns": {
            "type": "integer",
            "minimum": 1
          },
          "sideEffectsMode": {
            "type": "string"
          },
          "simulator": {
            "type": "object",
            "required": ["kind"],
            "properties": {
              "kind": {
                "type": "string"
              },
              "turns": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["text"],
                  "properties": {
                    "text": {
                      "type": "string"
                    },
                    "metadata": {
                      "type": "object"
                    }
                  }
                }
              },
              "instructions": {
                "type": "string"
              },
              "seedTurns": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["text"],
                  "properties": {
                    "text": {
                      "type": "string"
                    },
                    "metadata": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          },
          "simulatorTurns": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "intentProfile": {
            "type": "object"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
