{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cautilus.skill_test_cases.v1",
  "type": "object",
  "required": [
    "schemaVersion",
    "skillId",
    "cases"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "cautilus.skill_test_cases.v1"
    },
    "skillId": {
      "type": "string"
    },
    "skillDisplayName": {
      "type": "string"
    },
    "instructionSurface": {
      "type": "object",
      "required": ["surfaceLabel", "files"],
      "properties": {
        "surfaceLabel": {
          "type": "string"
        },
        "files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["path"],
            "properties": {
              "path": {
                "type": "string"
              },
              "content": {
                "type": "string"
              },
              "sourceFile": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "repeatCount": {
      "type": "integer",
      "minimum": 1
    },
    "minConsensusCount": {
      "type": "integer",
      "minimum": 1
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "caseId",
          "evaluationKind",
          "prompt"
        ],
        "properties": {
          "caseId": {
            "type": "string"
          },
          "targetKind": {
            "type": "string",
            "enum": ["public_skill", "profile", "integration"]
          },
          "targetId": {
            "type": "string"
          },
          "displayName": {
            "type": "string"
          },
          "evaluationKind": {
            "type": "string",
            "enum": ["trigger", "execution"]
          },
          "prompt": {
            "type": "string"
          },
          "expectedTrigger": {
            "type": "string",
            "enum": ["must_invoke", "must_not_invoke"]
          },
          "expectedRouting": {
            "type": "object",
            "properties": {
              "selectedSkill": {
                "type": ["string", "null"]
              },
              "selectedSupport": {
                "type": ["string", "null"]
              },
              "firstToolCallPattern": {
                "type": "string"
              }
            }
          },
          "instructionSurface": {
            "type": "object",
            "required": ["surfaceLabel", "files"],
            "properties": {
              "surfaceLabel": {
                "type": "string"
              },
              "files": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["path"],
                  "properties": {
                    "path": {
                      "type": "string"
                    },
                    "content": {
                      "type": "string"
                    },
                    "sourceFile": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "thresholds": {
            "type": "object",
            "properties": {
              "max_total_tokens": {
                "type": "integer",
                "minimum": 0
              },
              "max_duration_ms": {
                "type": "integer",
                "minimum": 0
              },
              "max_cost_usd": {
                "type": "number",
                "minimum": 0
              }
            }
          },
          "repeatCount": {
            "type": "integer",
            "minimum": 1
          },
          "minConsensusCount": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    }
  }
}
