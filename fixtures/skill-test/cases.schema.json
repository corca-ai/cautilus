{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cautilus.skill_test_cases.v1",
  "type": "object",
  "required": [
    "schemaVersion",
    "skillId",
    "cases"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "cautilus.skill_test_cases.v1"
    },
    "skillId": {
      "type": "string"
    },
    "skillDisplayName": {
      "type": "string"
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "caseId",
          "evaluationKind",
          "prompt"
        ],
        "properties": {
          "caseId": {
            "type": "string"
          },
          "targetKind": {
            "type": "string",
            "enum": ["public_skill", "profile", "integration"]
          },
          "targetId": {
            "type": "string"
          },
          "displayName": {
            "type": "string"
          },
          "evaluationKind": {
            "type": "string",
            "enum": ["trigger", "execution"]
          },
          "prompt": {
            "type": "string"
          },
          "expectedTrigger": {
            "type": "string",
            "enum": ["must_invoke", "must_not_invoke"]
          },
          "thresholds": {
            "type": "object",
            "properties": {
              "max_total_tokens": {
                "type": "integer",
                "minimum": 0
              },
              "max_duration_ms": {
                "type": "integer",
                "minimum": 0
              },
              "max_cost_usd": {
                "type": "number",
                "minimum": 0
              }
            }
          }
        }
      }
    }
  }
}
