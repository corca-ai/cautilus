{
  "schemaVersion": "cautilus.cli_evaluation_inputs.v1",
  "candidate": "current-cautilus-cli",
  "baseline": "current-doctor-contract",
  "intent": "The doctor command should explain missing adapter setup without forcing the operator to guess the recovery step.",
  "surfaceId": "doctor-missing-adapter",
  "mode": "held_out",
  "workingDirectory": "../..",
  "command": [
    "node",
    "./bin/cautilus",
    "doctor",
