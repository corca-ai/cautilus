{
  "groups": [
    { "id": "run", "label": "Discover claims and run bounded evals" },
    { "id": "setup", "label": "Set up and check a repo" },
    { "id": "results", "label": "Review proof packets and improve behavior" },
    { "id": "introspection", "label": "Introspection" }
  ],
  "commands": [
    {
      "path": ["claim", "discover"],
      "group": "run",
      "usage": "cautilus claim discover --repo-root <path> [--source <path>] [--previous <claims.json> --refresh-plan] [--output <claims-or-refresh-plan.json>]",
      "example": "cautilus claim discover --repo-root . --output /tmp/cautilus-claims.json",
      "notes": [
        "`--example-output` prints a minimal proof-plan packet.",
        "The command emits `cautilus.claim_proof_plan.v1`: a source-ref-backed plan, not a verdict that the repo is correct.",
        "Default discovery starts from adapter-owned entries or README.md/AGENTS.md/CLAUDE.md and follows repo-local Markdown links to depth 3.",
        "Use `--source` repeatedly when the host repo wants an explicit truth-surface inventory instead of the conservative defaults.",
        "Use `--previous <claims.json> --refresh-plan` when an agent workflow needs deterministic refresh planning without a separate refresh command.",
        "Refresh-plan packets include `refreshSummary` so agents can explain changed sources, changed claims, and next choices without guessing raw JSON fields.",
        "Refresh-plan output is not a saved claim map update; write it to a `refresh-plan*.json` artifact instead of the configured latest/reviewed/evidenced claim-state paths."
      ]
    },
    {
      "path": ["agent", "status"],
      "group": "introspection",
      "usage": "cautilus agent status --repo-root <path> [--json]",
      "example": "cautilus agent status --repo-root . --json",
      "notes": [
        "Emits the no-input orientation packet for bundled skills.",
        "The packet reads binary, agent-surface, adapter, and claim-state availability before a branch is selected."
      ]
    },
    {
      "path": ["claim", "show"],
      "group": "results",
      "usage": "cautilus claim show --input <claims.json> [--sample-claims <n>] [--output <summary.json>]",
      "example": "cautilus claim show --input /tmp/cautilus-claims.json --sample-claims 10",
      "notes": [
        "Summarizes an existing `cautilus.claim_proof_plan.v1` packet without rescanning.",
        "`--sample-claims` includes a bounded set of stable claim fields for agents that need examples before choosing the next branch.",
        "Includes `evidenceSatisfaction` so satisfied claims and their evidence refs are visible from the status summary.",
        "This command emits `cautilus.claim_status_summary.v1` for agents that need current status before choosing review, test, scenario, or alignment work."
      ]
    },
    {
      "path": ["claim", "review", "prepare-input"],
      "group": "results",
      "usage": "cautilus claim review prepare-input --claims <claims.json> [--action-bucket <bucket>] [--max-clusters <n>] [--max-claims-per-cluster <n>] [--excerpt-chars <n>] [--allow-stale-claims] [--output <review-input.json>]",
      "example": "cautilus claim review prepare-input --claims /tmp/cautilus-claims.json --action-bucket human-align-surfaces --max-clusters 20 --output /tmp/cautilus-claim-review-input.json",
      "notes": [
        "Prepares deterministic `cautilus.claim_review_input.v1` clusters for agent or subagent review.",
        "Rejects stale claim packets by default; staleness means recorded claim sources changed, not merely that generated claim artifacts were committed later.",
        "May include `possibleEvidenceRefs` from adapter `evidence_roots`, but those refs are hints and cannot satisfy claims.",
        "`--action-bucket` focuses review input on one status action bucket and records non-matching claims under `skippedClaims`.",
        "Skips claims already marked `evidenceStatus=satisfied` or already reviewed by default and records them under `skippedClaims` so review budget stays focused on unresolved heuristic claims.",
        "The command does not call an LLM and does not mark claims satisfied."
      ]
    },
    {
      "path": ["claim", "review", "apply-result"],
      "group": "results",
      "usage": "cautilus claim review apply-result --claims <claims.json> --review-result <review-result.json> [--allow-stale-claims] [--output <reviewed-claims.json>]",
      "example": "cautilus claim review apply-result --claims /tmp/cautilus-claims.json --review-result /tmp/cautilus-claim-review-result.json --output /tmp/cautilus-reviewed-claims.json",
      "notes": [
        "Applies deterministic label and evidence updates from `cautilus.claim_review_result.v1` to an existing claim packet.",
        "Rejects stale claim packets by default before merging review results; packet-only HEAD drift is reported without blocking this command.",
        "`evidenceStatus=satisfied` requires direct or verified evidence refs; possible evidence refs cannot satisfy a claim."
      ]
    },
    {
      "path": ["claim", "plan-evals"],
      "group": "results",
      "usage": "cautilus claim plan-evals --claims <reviewed-claims.json> [--max-claims <n>] [--allow-stale-claims] [--output <eval-plan.json>]",
      "example": "cautilus claim plan-evals --claims /tmp/cautilus-reviewed-claims.json --output /tmp/cautilus-eval-plan.json",
      "notes": [
        "Emits `cautilus.claim_eval_plan.v1` for reviewed `cautilus-eval` claims that are ready to verify.",
        "Skips claims that already have `evidenceStatus=satisfied`; they do not need a new eval fixture plan by default.",
        "Rejects stale claim packets by default before planning eval fixtures; generated claim artifact commits do not make the source inventory stale.",
        "The command plans eval fixtures but does not write host-owned fixtures, prompts, runners, or policy."
      ]
    },
    {
      "path": ["claim", "validate"],
      "group": "results",
      "usage": "cautilus claim validate --claims <claims.json> [--output <validation-report.json>]",
      "example": "cautilus claim validate --claims /tmp/cautilus-reviewed-claims.json --output /tmp/cautilus-claim-validation.json",
      "notes": [
        "Emits `cautilus.claim_validation_report.v1` and exits non-zero when packet shape or evidence refs are invalid.",
        "The command validates existing packets but does not mutate claims or search for evidence."
      ]
    },
    {
      "path": ["scenario", "review-conversations"],
      "group": "results",
      "usage": "cautilus scenario review-conversations [args]",
      "example": "cautilus scenario review-conversations --input ./fixtures/scenario-conversation-review/input.json",
      "notes": [
        "`--example-input` prints a minimal valid conversation-review input packet.",
        "This read-only surface stays scenario-centric: it links normalized chatbot threads to scenario proposals instead of acting like a generic audit browser."
      ]
    },
    {
      "path": ["eval", "test"],
      "group": "run",
      "usage": "cautilus eval test [args]",
      "example": "cautilus eval test --repo-root . --adapter-name self-dogfood-eval --fixture ./fixtures/eval/dev/repo/checked-in-agents-routing.fixture.json",
      "notes": [
        "Runs one checked-in evaluation fixture through an adapter-owned runner, then evaluates the observed packet.",
        "The four first-class presets are `dev/repo`, `dev/skill`, `app/chat`, and `app/prompt`.",
        "`--runtime codex|claude|fixture|product` selects the runner backend placeholder; use `fixture` for cheap command-routing smoke tests, and `product` for headless product-path runners."
      ]
    },
    {
      "path": ["eval", "evaluate"],
      "group": "run",
      "usage": "cautilus eval evaluate [args]",
      "example": "cautilus eval evaluate --input ./eval-observed.json",
      "notes": [
        "Evaluates one already-observed packet without launching the host runner again.",
        "The packet schema selects the preset: `dev/repo`, `dev/skill`, `app/chat`, or `app/prompt`."
      ]
    },
    {
      "path": ["eval", "live", "discover"],
      "group": "run",
      "usage": "cautilus eval live discover [args]",
      "example": "cautilus eval live discover --repo-root .",
      "notes": [
        "Discovers live app targets for app evals."
      ]
    },
    {
      "path": ["eval", "live", "run"],
      "group": "run",
      "usage": "cautilus eval live run --instance-id <id> --request-file <request.json> --output-file <result.json> [args]",
      "example": "cautilus eval live run --repo-root . --instance-id ceal --request-file /tmp/request.json --output-file /tmp/result.json",
      "notes": [
        "Runs one bounded live app request and writes `cautilus.live_run_invocation_result.v1`.",
        "The adapter may still delegate actual runtime launch to a consumer-owned command template."
      ]
    },
    {
      "path": ["eval", "live", "prepare-request-batch"],
      "group": "run",
      "usage": "cautilus eval live prepare-request-batch --input <prepare-input.json> [--output <request-batch.json>]",
      "example": "cautilus eval live prepare-request-batch --input /tmp/prepare-input.json --output /tmp/request-batch.json",
      "notes": [
        "Turns draft scenarios or normalized catalog candidates into `cautilus.live_run_invocation_request_batch.v1`."
      ]
    },
    {
      "path": ["eval", "live", "run-scenarios"],
      "group": "run",
      "usage": "cautilus eval live run-scenarios --instance-id <id> --requests-file <batch.json> --output-file <result.json> [--concurrency <n>] [args]",
      "example": "cautilus eval live run-scenarios --repo-root . --instance-id ceal --requests-file /tmp/request-batch.json --output-file /tmp/batch-result.json --concurrency 4",
      "notes": [
        "Runs an explicit live request batch for app evals and writes `cautilus.live_run_invocation_batch_result.v1`.",
        "Each attempt writes nested request/result artifacts under `<output-file>.d/runs/`."
      ]
    },
    {
      "path": ["eval", "live", "run-simulator-persona"],
      "group": "run",
      "usage": "cautilus eval live run-simulator-persona --workspace <dir> --simulator-request-file <request.json> --simulator-result-file <result.json> --backend codex_exec|claude_p|fixture [args]",
      "example": "cautilus eval live run-simulator-persona --workspace . --simulator-request-file /tmp/simulator-request.json --simulator-result-file /tmp/simulator-result.json --backend fixture --fixture-results-file fixtures/live-run/persona-fixture.json",
      "notes": [
        "Turns one persona_prompt simulator request into one canonical simulator result packet for app evals."
      ]
    },
    {
      "path": ["scenario", "propose"],
      "group": "run",
      "usage": "cautilus scenario propose [args]",
      "example": "cautilus scenario propose --input ./fixtures/scenario-proposals/standalone-input.json",
      "notes": [
        "The canonical JSON output preserves the full ranked proposal list for agents.",
        "The output packet also emits an `attentionView`, which is a bounded human-facing shortlist derived from the full ranked set."
      ]
    },
    {
      "path": ["scenario", "prepare-input"],
      "group": "run",
      "usage": "cautilus scenario prepare-input [args]",
      "example": "cautilus scenario prepare-input --candidates ./fixtures/scenario-proposals/candidates.json --registry ./fixtures/scenario-proposals/registry.json --coverage ./fixtures/scenario-proposals/coverage.json"
    },
    {
      "path": ["scenario", "normalize", "chatbot"],
      "group": "run",
      "usage": "cautilus scenario normalize chatbot [args]",
      "example": "cautilus scenario normalize chatbot --input ./fixtures/scenario-proposals/chatbot-input.json"
    },
    {
      "path": ["scenario", "normalize", "skill"],
      "group": "run",
      "usage": "cautilus scenario normalize skill [args]",
      "example": "cautilus scenario normalize skill --input ./fixtures/scenario-proposals/skill-input.json"
    },
    {
      "path": ["scenario", "normalize", "workflow"],
      "group": "run",
      "usage": "cautilus scenario normalize workflow [args]",
      "example": "cautilus scenario normalize workflow --input ./fixtures/scenario-proposals/workflow-input.json"
    },
    {
      "path": ["workspace", "start"],
      "group": "run",
      "usage": "cautilus workspace start [args]",
      "example": "eval \"$(cautilus workspace start --label mode-held-out)\""
    },
    {
      "path": ["install"],
      "group": "setup",
      "usage": "cautilus install [--repo-root <path>] [--overwrite] [--json]",
      "example": "cautilus install --repo-root ."
    },
    {
      "path": ["update"],
      "group": "setup",
      "usage": "cautilus update [--repo-root <path>] [--json]",
      "example": "cautilus update --repo-root ."
    },
    {
      "path": ["adapter", "resolve"],
      "group": "setup",
      "usage": "cautilus adapter resolve [args]",
      "example": "cautilus adapter resolve --repo-root ."
    },
    {
      "path": ["adapter", "init"],
      "group": "setup",
      "usage": "cautilus adapter init [--scenario <chatbot|skill|workflow>] [args]",
      "example": "cautilus adapter init --repo-root . --scenario skill"
    },
    {
      "path": ["doctor"],
      "group": "setup",
      "usage": "cautilus doctor [args]",
      "example": "cautilus doctor --repo-root .",
      "notes": [
        "Default `doctor` validates the unnamed checked-in adapter path.",
        "Use `cautilus doctor --repo-root . --next-action` when you want one current onboarding step plus the exact follow-up loop.",
        "If your repo intentionally keeps only named adapters under `.agents/cautilus-adapters/`, use `cautilus doctor --repo-root . --adapter-name <name>` for repo-scope validation.",
        "A ready repo payload includes `first_bounded_run`, which adds a starter `eval test -> eval evaluate` packet loop."
      ]
    },
    {
      "path": ["healthcheck"],
      "group": "setup",
      "usage": "cautilus healthcheck [--json]",
      "example": "cautilus healthcheck --json"
    },
    {
      "path": ["workspace", "prepare-compare"],
      "group": "setup",
      "usage": "cautilus workspace prepare-compare [args]",
      "example": "cautilus workspace prepare-compare --repo-root . --baseline-ref origin/main --output-dir /tmp/cautilus-compare"
    },
    {
      "path": ["workspace", "prune-artifacts"],
      "group": "setup",
      "usage": "cautilus workspace prune-artifacts [args]",
      "example": "cautilus workspace prune-artifacts --root /tmp/cautilus-runs --keep-last 20"
    },
    {
      "path": ["scenario", "summarize-telemetry"],
      "group": "results",
      "usage": "cautilus scenario summarize-telemetry [args]",
      "example": "cautilus scenario summarize-telemetry --results ./results.json"
    },
    {
      "path": ["evidence", "prepare-input"],
      "group": "results",
      "usage": "cautilus evidence prepare-input [args]",
      "example": "cautilus evidence prepare-input --report-file /tmp/cautilus-mode/report.json --scenario-results-file /tmp/cautilus-mode/held_out-scenario-results.json --run-audit-file /tmp/cautilus-run-audit/run-audit-summary.json"
    },
    {
      "path": ["evidence", "bundle"],
      "group": "results",
      "usage": "cautilus evidence bundle [args]",
      "example": "cautilus evidence bundle --input /tmp/cautilus-evidence/input.json"
    },
    {
      "path": ["report", "build"],
      "group": "results",
      "usage": "cautilus report build [args]",
      "example": "cautilus report build --example-input",
      "notes": [
        "`--example-input` prints a minimal valid report-input packet.",
        "`humanReviewFindings` entries require `severity` and `message`, with optional `path`."
      ]
    },
    {
      "path": ["report", "render-html"],
      "group": "results",
      "usage": "cautilus report render-html --input <report.json> [--output <report.html>]",
      "example": "cautilus report render-html --input /tmp/cautilus-mode/report.json"
    },
    {
      "path": ["review", "render-html"],
      "group": "results",
      "usage": "cautilus review render-html --input <review.json> [--output <review.html>]",
      "example": "cautilus review render-html --input /tmp/cautilus-review/review.json"
    },
    {
      "path": ["review", "render-variants-summary-html"],
      "group": "results",
      "usage": "cautilus review render-variants-summary-html --input <review-summary.json> [--output <review-summary.html>]",
      "example": "cautilus review render-variants-summary-html --input /tmp/cautilus-review/review-summary.json"
    },
    {
      "path": ["workspace", "render-compare-html"],
      "group": "results",
      "usage": "cautilus workspace render-compare-html --input <compare-artifact.json> [--output <compare.html>]",
      "example": "cautilus workspace render-compare-html --input /tmp/cautilus-compare/compare-artifact.json"
    },
    {
      "path": ["scenario", "render-proposals-html"],
      "group": "results",
      "usage": "cautilus scenario render-proposals-html --input <proposals.json> [--output <proposals.html>]",
      "example": "cautilus scenario render-proposals-html --input /tmp/cautilus-proposals/proposals.json"
    },
    {
      "path": ["scenario", "render-conversation-review-html"],
      "group": "results",
      "usage": "cautilus scenario render-conversation-review-html --input <conversation-review.json> [--output <conversation-review.html>]",
      "example": "cautilus scenario render-conversation-review-html --input /tmp/cautilus-review/conversation-review.json"
    },
    {
      "path": ["evidence", "render-html"],
      "group": "results",
      "usage": "cautilus evidence render-html --input <evidence-bundle.json> [--output <evidence-bundle.html>]",
      "example": "cautilus evidence render-html --input /tmp/cautilus-evidence/evidence-bundle.json"
    },
    {
      "path": ["artifacts", "render-index-html"],
      "group": "results",
      "usage": "cautilus artifacts render-index-html --run-dir <path> [--output <index.html>]",
      "example": "cautilus artifacts render-index-html --run-dir artifacts/self-dogfood/latest"
    },
    {
      "path": ["review", "prepare-input"],
      "group": "results",
      "usage": "cautilus review prepare-input [args]",
      "example": "cautilus review prepare-input --repo-root . --report-file /tmp/cautilus-mode/report.json",
      "notes": [
        "If you need a minimal valid report packet before running review, start with `cautilus report build --example-input`.",
        "That example shows the minimum `humanReviewFindings` shape: `{ \"severity\": \"concern\", \"message\": \"...\", \"path\": \"optional\" }`."
      ]
    },
    {
      "path": ["review", "build-prompt-input"],
      "group": "results",
      "usage": "cautilus review build-prompt-input [args]",
      "example": "cautilus review build-prompt-input --review-packet /tmp/cautilus-mode/review.json"
    },
    {
      "path": ["review", "render-prompt"],
      "group": "results",
      "usage": "cautilus review render-prompt [args]",
      "example": "cautilus review render-prompt --input /tmp/cautilus-mode/review-prompt-input.json"
    },
    {
      "path": ["review", "variants"],
      "group": "results",
      "usage": "cautilus review variants --repo-root <repo> --workspace <dir> [--prompt-file <review.md> --schema-file <schema.json>] [--output-dir <dir>]",
      "example": "cautilus review variants --repo-root . --workspace . --prompt-file ./review.md --schema-file ./schema.json --output-dir /tmp/cautilus-review",
      "notes": [
        "Use `--prompt-file` plus `--schema-file` for ad-hoc bounded review without first building a review packet.",
        "Omit those flags when the adapter or review prompt input provides the default prompt and schema."
      ]
    },
    {
      "path": ["optimize", "prepare-input"],
      "group": "results",
      "usage": "cautilus optimize prepare-input [args]",
      "example": "cautilus optimize prepare-input --report-file /tmp/cautilus-mode/report.json --review-summary /tmp/cautilus-review/review-summary.json --history-file /tmp/cautilus-history/scenario-history.snapshot.json --target prompt --budget medium",
      "notes": [
        "`optimize` is the improvement front door; use it only after the claim and eval proof surface are explicit.",
        "This command prepares a bounded improvement packet from report, review, and history evidence."
      ]
    },
    {
      "path": ["optimize", "search", "prepare-input"],
      "group": "results",
      "usage": "cautilus optimize search prepare-input [args]",
      "example": "cautilus optimize search prepare-input --optimize-input /tmp/cautilus-optimize/input.json --held-out-results-file /tmp/cautilus-mode/held_out-scenario-results.json --target-file .agents/review.prompt.md --budget light",
      "notes": [
        "Prepares a bounded search packet above an explicit optimize input and held-out evidence."
      ]
    },
    {
      "path": ["optimize", "search", "run"],
      "group": "results",
      "usage": "cautilus optimize search run [args]",
      "example": "cautilus optimize search run --input /tmp/cautilus-optimize/search-input.json --json",
      "notes": [
        "Runs the bounded search and emits a checkpointed result packet; it is not an open-ended retry loop."
      ]
    },
    {
      "path": ["optimize", "propose"],
      "group": "results",
      "usage": "cautilus optimize propose [args]",
      "example": "cautilus optimize propose --input /tmp/cautilus-optimize/input.json",
      "notes": [
        "Produces a bounded improvement proposal from an explicit optimize input."
      ]
    },
    {
      "path": ["optimize", "build-artifact"],
      "group": "results",
      "usage": "cautilus optimize build-artifact [args]",
      "example": "cautilus optimize build-artifact --proposal-file /tmp/cautilus-optimize/proposal.json",
      "notes": [
        "Builds the reviewable revision artifact from an accepted improvement proposal."
      ]
    },
    {
      "path": ["self-dogfood", "render-html"],
      "group": "results",
      "usage": "cautilus self-dogfood render-html [args]",
      "example": "cautilus self-dogfood render-html --latest-dir ./artifacts/self-dogfood/latest"
    },
    {
      "path": ["self-dogfood", "render-experiments-html"],
      "group": "results",
      "usage": "cautilus self-dogfood render-experiments-html [args]",
      "example": "cautilus self-dogfood render-experiments-html --latest-dir ./artifacts/self-dogfood/experiments/latest"
    },
    {
      "path": ["commands"],
      "group": "introspection",
      "usage": "cautilus commands [--json]",
      "example": "cautilus commands --json"
    },
    {
      "path": ["scenarios"],
      "group": "introspection",
      "usage": "cautilus scenarios [--json]",
      "example": "cautilus scenarios --json"
    },
    {
      "path": ["version"],
      "group": "introspection",
      "usage": "cautilus version [--verbose] [--check]",
      "example": "cautilus version --verbose --check"
    }
  ]
}
