    },
    {
      "path": ["optimize", "build-artifact"],
      "script": "scripts/agent-runtime/build-revision-artifact.mjs"
    },
    {
      "path": ["review", "prepare-input"],
      "script": "scripts/agent-runtime/build-review-packet.mjs"
    },
    {
      "path": ["review", "build-prompt-input"],
      "script": "scripts/agent-runtime/build-review-prompt-input.mjs"
    },
    {
      "path": ["review", "render-prompt"],
      "script": "scripts/agent-runtime/render-review-prompt.mjs"
    },
    {
      "path": ["cli", "evaluate"],
      "script": "scripts/agent-runtime/evaluate-cli-intent.mjs"
    },
    {
      "path": ["review", "variants"],
      "script": "scripts/agent-runtime/run-workbench-executor-variants.mjs"
    }
  ]
}
