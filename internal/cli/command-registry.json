{
  "groups": [
    { "id": "run", "label": "Run an evaluation scenario" },
    { "id": "setup", "label": "Set up and check a repo" },
    { "id": "results", "label": "Turn results into next moves" },
    { "id": "introspection", "label": "Introspection" }
  ],
  "commands": [
    {
      "path": ["scenario", "normalize", "chatbot"],
      "group": "run",
      "usage": "cautilus scenario normalize chatbot [args]",
      "example": "cautilus scenario normalize chatbot --input ./fixtures/scenario-proposals/chatbot-input.json"
    },
    {
      "path": ["scenario", "normalize", "skill"],
      "group": "run",
      "usage": "cautilus scenario normalize skill [args]",
      "example": "cautilus scenario normalize skill --input ./fixtures/scenario-proposals/skill-input.json"
    },
    {
      "path": ["scenario", "normalize", "workflow"],
      "group": "run",
      "usage": "cautilus scenario normalize workflow [args]",
      "example": "cautilus scenario normalize workflow --input ./fixtures/scenario-proposals/workflow-input.json"
    },
    {
      "path": ["scenario", "prepare-input"],
      "group": "run",
      "usage": "cautilus scenario prepare-input [args]",
      "example": "cautilus scenario prepare-input --candidates ./fixtures/scenario-proposals/candidates.json --registry ./fixtures/scenario-proposals/registry.json --coverage ./fixtures/scenario-proposals/coverage.json"
    },
    {
      "path": ["scenario", "propose"],
      "group": "run",
      "usage": "cautilus scenario propose [args]",
      "example": "cautilus scenario propose --input ./fixtures/scenario-proposals/standalone-input.json",
      "notes": [
        "The canonical JSON output preserves the full ranked proposal list for agents.",
        "The output packet also emits an `attentionView`, which is a bounded human-facing shortlist derived from the full ranked set."
      ]
    },
    {
      "path": ["scenario", "review-conversations"],
      "group": "results",
      "usage": "cautilus scenario review-conversations [args]",
      "example": "cautilus scenario review-conversations --input ./fixtures/scenario-conversation-review/input.json",
      "notes": [
        "`--example-input` prints a minimal valid conversation-review input packet.",
        "This read-only surface stays scenario-centric: it links normalized chatbot threads to scenario proposals instead of acting like a generic audit browser."
      ]
    },
    {
      "path": ["instruction-surface", "test"],
      "group": "run",
      "usage": "cautilus instruction-surface test [args]",
      "example": "cautilus instruction-surface test --repo-root . --adapter-name self-dogfood-instruction-surface"
    },
    {
      "path": ["instruction-surface", "evaluate"],
      "group": "run",
      "usage": "cautilus instruction-surface evaluate [args]",
      "example": "cautilus instruction-surface evaluate --input ./fixtures/instruction-surface/input.json"
    },
    {
      "path": ["skill", "test"],
      "group": "run",
      "usage": "cautilus skill test [args]",
      "example": "cautilus skill test --repo-root . --adapter-name self-dogfood-skill-test"
    },
    {
      "path": ["skill", "evaluate"],
      "group": "run",
      "usage": "cautilus skill evaluate [args]",
      "example": "cautilus skill evaluate --input ./fixtures/skill-evaluation/input.json"
    },
    {
      "path": ["mode", "evaluate"],
      "group": "run",
      "usage": "cautilus mode evaluate [args]",
      "example": "cautilus mode evaluate --repo-root . --mode held_out --intent 'Operator-facing behavior should remain legible.' --baseline-ref origin/main --output-dir /tmp/cautilus-mode"
    },
    {
      "path": ["workspace", "start"],
      "group": "run",
      "usage": "cautilus workspace start [args]",
      "example": "eval \"$(cautilus workspace start --label mode-held-out)\""
    },
    {
      "path": ["install"],
      "group": "setup",
      "usage": "cautilus install [--repo-root <path>] [--overwrite] [--json]",
      "example": "cautilus install --repo-root ."
    },
    {
      "path": ["update"],
      "group": "setup",
      "usage": "cautilus update [--repo-root <path>] [--json]",
      "example": "cautilus update --repo-root ."
    },
    {
      "path": ["skills", "install"],
      "group": "setup",
      "usage": "cautilus skills install [--overwrite]",
      "example": "cautilus skills install"
    },
    {
      "path": ["adapter", "resolve"],
      "group": "setup",
      "usage": "cautilus adapter resolve [args]",
      "example": "cautilus adapter resolve --repo-root ."
    },
    {
      "path": ["adapter", "init"],
      "group": "setup",
      "usage": "cautilus adapter init [--scenario <chatbot|skill|workflow>] [args]",
      "example": "cautilus adapter init --repo-root . --scenario skill"
    },
    {
      "path": ["doctor"],
      "group": "setup",
      "usage": "cautilus doctor [args]",
      "example": "cautilus doctor --repo-root .",
      "notes": [
        "Default `doctor` validates the unnamed checked-in adapter path.",
        "If your repo intentionally keeps only named adapters under `.agents/cautilus-adapters/`, use `cautilus doctor --repo-root . --adapter-name <name>` for repo-scope validation.",
        "A ready repo payload includes `first_bounded_run`, which mirrors `cautilus scenarios --json` and adds a starter `mode evaluate -> review` loop."
      ]
    },
    {
      "path": ["workbench", "discover"],
      "group": "introspection",
      "usage": "cautilus workbench discover [args]",
      "example": "cautilus workbench discover --repo-root .",
      "notes": [
        "A workbench instance is one live consumer target on this host that Cautilus can select by stable id.",
        "The command resolves either explicit adapter instances or a consumer-owned discovery probe into the canonical catalog packet."
      ]
    },
    {
      "path": ["workbench", "run-live"],
      "group": "run",
      "usage": "cautilus workbench run-live --instance-id <id> --request-file <request.json> --output-file <result.json> [args]",
      "example": "cautilus workbench run-live --repo-root . --instance-id ceal --request-file /tmp/request.json --output-file /tmp/result.json",
      "notes": [
        "The selected instance id must come from `cautilus workbench discover`.",
        "The adapter may still delegate actual runtime launch to a consumer-owned `consumer_command_template`."
      ]
    },
    {
      "path": ["workbench", "prepare-request-batch"],
      "group": "run",
      "usage": "cautilus workbench prepare-request-batch --input <prepare-input.json> [--output <request-batch.json>]",
      "example": "cautilus workbench prepare-request-batch --input /tmp/prepare-input.json --output /tmp/request-batch.json",
      "notes": [
        "This command turns either `cautilus.live_run_invocation_batch_prepare_input.v1` or `cautilus.live_run_invocation_batch_prepare_catalog_input.v1` into the canonical `cautilus.live_run_invocation_request_batch.v1` batch artifact.",
        "The current slice accepts checked-in `cautilus.scenario.v1` draft scenarios or normalized catalog candidates, preserves optional batch retry policy, and supports exact `scenarioIds` plus `requiredTags` filtering."
      ]
    },
    {
      "path": ["workbench", "run-scenarios"],
      "group": "run",
      "usage": "cautilus workbench run-scenarios --instance-id <id> --requests-file <batch.json> --output-file <result.json> [--concurrency <n>] [args]",
      "example": "cautilus workbench run-scenarios --repo-root . --instance-id ceal --requests-file /tmp/request-batch.json --output-file /tmp/batch-result.json --concurrency 4",
      "notes": [
        "This command accepts an explicit `cautilus.live_run_invocation_request_batch.v1` file and reuses the same live-run adapter seam per request.",
        "Each attempt writes its own nested result artifact under `<output-file>.d/runs/`, while the top-level output aggregates final request counts, retry attempt counts, transient-class counts, and per-request attempt history."
      ]
    },
    {
      "path": ["workbench", "run-simulator-persona"],
      "group": "run",
      "usage": "cautilus workbench run-simulator-persona --workspace <dir> --simulator-request-file <request.json> --simulator-result-file <result.json> --backend codex_exec|claude_p|fixture [args]",
      "example": "cautilus workbench run-simulator-persona --workspace . --simulator-request-file /tmp/simulator-request.json --simulator-result-file /tmp/simulator-result.json --backend fixture --fixture-results-file fixtures/live-run/persona-fixture.json",
      "notes": [
        "This product-owned helper turns one persona_prompt simulator request into one canonical simulator result packet.",
        "The adapter still chooses the backend and any fixture or provider-specific flags through its command template."
      ]
    },
    {
      "path": ["healthcheck"],
      "group": "setup",
      "usage": "cautilus healthcheck [--json]",
      "example": "cautilus healthcheck --json"
    },
    {
      "path": ["workspace", "prepare-compare"],
      "group": "setup",
      "usage": "cautilus workspace prepare-compare [args]",
      "example": "cautilus workspace prepare-compare --repo-root . --baseline-ref origin/main --output-dir /tmp/cautilus-compare"
    },
    {
      "path": ["workspace", "prune-artifacts"],
      "group": "setup",
      "usage": "cautilus workspace prune-artifacts [args]",
      "example": "cautilus workspace prune-artifacts --root /tmp/cautilus-runs --keep-last 20"
    },
    {
      "path": ["scenario", "summarize-telemetry"],
      "group": "results",
      "usage": "cautilus scenario summarize-telemetry [args]",
      "example": "cautilus scenario summarize-telemetry --results ./results.json"
    },
    {
      "path": ["evidence", "prepare-input"],
      "group": "results",
      "usage": "cautilus evidence prepare-input [args]",
      "example": "cautilus evidence prepare-input --report-file /tmp/cautilus-mode/report.json --scenario-results-file /tmp/cautilus-mode/held_out-scenario-results.json --run-audit-file /tmp/cautilus-run-audit/run-audit-summary.json"
    },
    {
      "path": ["evidence", "bundle"],
      "group": "results",
      "usage": "cautilus evidence bundle [args]",
      "example": "cautilus evidence bundle --input /tmp/cautilus-evidence/input.json"
    },
    {
      "path": ["report", "build"],
      "group": "results",
      "usage": "cautilus report build [args]",
      "example": "cautilus report build --example-input",
      "notes": [
        "`--example-input` prints a minimal valid report-input packet.",
        "`humanReviewFindings` entries require `severity` and `message`, with optional `path`."
      ]
    },
    {
      "path": ["report", "render-html"],
      "group": "results",
      "usage": "cautilus report render-html --input <report.json> [--output <report.html>]",
      "example": "cautilus report render-html --input /tmp/cautilus-mode/report.json"
    },
    {
      "path": ["review", "render-html"],
      "group": "results",
      "usage": "cautilus review render-html --input <review.json> [--output <review.html>]",
      "example": "cautilus review render-html --input /tmp/cautilus-review/review.json"
    },
    {
      "path": ["review", "render-variants-summary-html"],
      "group": "results",
      "usage": "cautilus review render-variants-summary-html --input <review-summary.json> [--output <review-summary.html>]",
      "example": "cautilus review render-variants-summary-html --input /tmp/cautilus-review/review-summary.json"
    },
    {
      "path": ["workspace", "render-compare-html"],
      "group": "results",
      "usage": "cautilus workspace render-compare-html --input <compare-artifact.json> [--output <compare.html>]",
      "example": "cautilus workspace render-compare-html --input /tmp/cautilus-compare/compare-artifact.json"
    },
    {
      "path": ["scenario", "render-proposals-html"],
      "group": "results",
      "usage": "cautilus scenario render-proposals-html --input <proposals.json> [--output <proposals.html>]",
      "example": "cautilus scenario render-proposals-html --input /tmp/cautilus-proposals/proposals.json"
    },
    {
      "path": ["scenario", "render-conversation-review-html"],
      "group": "results",
      "usage": "cautilus scenario render-conversation-review-html --input <conversation-review.json> [--output <conversation-review.html>]",
      "example": "cautilus scenario render-conversation-review-html --input /tmp/cautilus-review/conversation-review.json"
    },
    {
      "path": ["evidence", "render-html"],
      "group": "results",
      "usage": "cautilus evidence render-html --input <evidence-bundle.json> [--output <evidence-bundle.html>]",
      "example": "cautilus evidence render-html --input /tmp/cautilus-evidence/evidence-bundle.json"
    },
    {
      "path": ["artifacts", "render-index-html"],
      "group": "results",
      "usage": "cautilus artifacts render-index-html --run-dir <path> [--output <index.html>]",
      "example": "cautilus artifacts render-index-html --run-dir artifacts/self-dogfood/latest"
    },
    {
      "path": ["review", "prepare-input"],
      "group": "results",
      "usage": "cautilus review prepare-input [args]",
      "example": "cautilus review prepare-input --repo-root . --report-file /tmp/cautilus-mode/report.json",
      "notes": [
        "If you need a minimal valid report packet before running review, start with `cautilus report build --example-input`.",
        "That example shows the minimum `humanReviewFindings` shape: `{ \"severity\": \"concern\", \"message\": \"...\", \"path\": \"optional\" }`."
      ]
    },
    {
      "path": ["review", "build-prompt-input"],
      "group": "results",
      "usage": "cautilus review build-prompt-input [args]",
      "example": "cautilus review build-prompt-input --review-packet /tmp/cautilus-mode/review.json"
    },
    {
      "path": ["review", "render-prompt"],
      "group": "results",
      "usage": "cautilus review render-prompt [args]",
      "example": "cautilus review render-prompt --input /tmp/cautilus-mode/review-prompt-input.json"
    },
    {
      "path": ["review", "variants"],
      "group": "results",
      "usage": "cautilus review variants [args]",
      "example": "cautilus review variants --repo-root . --workspace . --output-dir /tmp/cautilus-review"
    },
    {
      "path": ["optimize", "prepare-input"],
      "group": "results",
      "usage": "cautilus optimize prepare-input [args]",
      "example": "cautilus optimize prepare-input --report-file /tmp/cautilus-mode/report.json --review-summary /tmp/cautilus-review/review-summary.json --history-file /tmp/cautilus-history/scenario-history.snapshot.json --target prompt --optimizer reflection --budget medium"
    },
    {
      "path": ["optimize", "search", "prepare-input"],
      "group": "results",
      "usage": "cautilus optimize search prepare-input [args]",
      "example": "cautilus optimize search prepare-input --optimize-input /tmp/cautilus-optimize/input.json --held-out-results-file /tmp/cautilus-mode/held_out-scenario-results.json --target-file .agents/review.prompt.md --budget light"
    },
    {
      "path": ["optimize", "search", "run"],
      "group": "results",
      "usage": "cautilus optimize search run [args]",
      "example": "cautilus optimize search run --input /tmp/cautilus-optimize/search-input.json --json"
    },
    {
      "path": ["optimize", "propose"],
      "group": "results",
      "usage": "cautilus optimize propose [args]",
      "example": "cautilus optimize propose --input /tmp/cautilus-optimize/input.json"
    },
    {
      "path": ["optimize", "build-artifact"],
      "group": "results",
      "usage": "cautilus optimize build-artifact [args]",
      "example": "cautilus optimize build-artifact --proposal-file /tmp/cautilus-optimize/proposal.json"
    },
    {
      "path": ["self-dogfood", "render-html"],
      "group": "results",
      "usage": "cautilus self-dogfood render-html [args]",
      "example": "cautilus self-dogfood render-html --latest-dir ./artifacts/self-dogfood/latest"
    },
    {
      "path": ["self-dogfood", "render-experiments-html"],
      "group": "results",
      "usage": "cautilus self-dogfood render-experiments-html [args]",
      "example": "cautilus self-dogfood render-experiments-html --latest-dir ./artifacts/self-dogfood/experiments/latest"
    },
    {
      "path": ["commands"],
      "group": "introspection",
      "usage": "cautilus commands [--json]",
      "example": "cautilus commands --json"
    },
    {
      "path": ["scenarios"],
      "group": "introspection",
      "usage": "cautilus scenarios [--json]",
      "example": "cautilus scenarios --json"
    },
    {
      "path": ["version"],
      "group": "introspection",
      "usage": "cautilus version [--verbose] [--check]",
      "example": "cautilus version --verbose --check"
    }
  ]
}
