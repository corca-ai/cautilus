{
  "entry": "docs/specs/index.spec.md",
  "adapters": [
    {
      "name": "cautilus",
      "command": [
        "node",
        "scripts/specdown/cautilus-adapter.mjs"
      ],
      "checks": [
        "cautilus-command"
      ]
    }
  ],
  "reporters": [
    {
      "builtin": "html",
      "outFile": ".artifacts/specdown/report"
    },
    {
      "builtin": "json",
      "outFile": ".artifacts/specdown/report.json"
    }
  ]
}
