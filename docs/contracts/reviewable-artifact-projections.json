{
  "schemaVersion": "cautilus.reviewable_artifact_projection_matrix.v1",
  "scope": {
    "included": "Shipped Cautilus-owned readable views generated by the CLI or bundled claim workflow.",
    "excluded": [
      "Consumer-owned custom report views",
      "Future renderer families not listed here",
      "Markdown preview snapshots used only for prose authoring"
    ],
    "truthSourcePolicy": "Each listed readable view is a projection over one or more machine-readable packet or source artifacts. Human comments, when supported, are written to a separate packet and do not mutate the rendered source."
  },
  "registryMatchers": [
    {"path": ["report", "render-html"], "usageIncludes": ["--input <report.json>", "--output <report.html>"]},
    {"path": ["review", "render-html"], "usageIncludes": ["--input <review.json>", "--output <review.html>"]},
    {"path": ["review", "render-variants-summary-html"], "usageIncludes": ["--input <review-summary.json>", "--output <review-summary.html>"]},
    {"path": ["workspace", "render-compare-html"], "usageIncludes": ["--input <compare-artifact.json>", "--output <compare.html>"]},
    {"path": ["scenario", "render-proposals-html"], "usageIncludes": ["--input <proposals.json>", "--output <proposals.html>"]},
    {"path": ["scenario", "render-conversation-review-html"], "usageIncludes": ["--input <conversation-review.json>", "--output <conversation-review.html>"]},
    {"path": ["evidence", "render-html"], "usageIncludes": ["--input <evidence-bundle.json>", "--output <evidence-bundle.html>"]},
    {"path": ["artifacts", "render-index-html"], "usageIncludes": ["--run-dir <path>", "--output <index.html>"]},
    {"path": ["review", "render-prompt"], "usageIncludes": ["review render-prompt"]},
    {"path": ["self-dogfood", "render-html"], "usageIncludes": ["self-dogfood render-html"]},
    {"path": ["self-dogfood", "render-experiments-html"], "usageIncludes": ["self-dogfood render-experiments-html"]}
  ],
  "surfaces": [
    {
      "id": "report-html",
      "readableView": "report.html",
      "sourceArtifacts": ["report.json"],
      "sourceSchemas": ["cautilus.report_packet.v2"],
      "renderer": "internal/runtime/report_html.go",
      "tests": ["internal/runtime/report_html_test.go"],
      "commands": ["cautilus report render-html"],
      "proofMarkers": [
        {"path": "internal/runtime/report_html.go", "contains": ["RenderReportHTMLFromFile", "ValidateReportPacket", "Generated from <code>report.json</code>"]},
        {"path": "internal/runtime/report_html_test.go", "contains": ["TestRenderReportHTMLFromFileRejectsLegacySchema", "TestWriteReportHTMLFromFileWritesNextToInput"]}
      ]
    },
    {
      "id": "review-html",
      "readableView": "review.html",
      "sourceArtifacts": ["review.json"],
      "sourceSchemas": ["cautilus.review_packet.v1"],
      "renderer": "internal/runtime/review_html.go",
      "tests": ["internal/runtime/review_html_test.go"],
      "commands": ["cautilus review render-html"],
      "proofMarkers": [
        {"path": "internal/runtime/review_html.go", "contains": ["RenderReviewPacketHTMLFromFile", "contracts.ReviewPacketSchema", "Generated from <code>review.json</code>"]},
        {"path": "internal/runtime/review_html_test.go", "contains": ["TestRenderReviewPacketHTMLFromFileRejectsWrongSchema", "TestWriteReviewPacketHTMLFromFileWritesNextToInput"]}
      ]
    },
    {
      "id": "review-summary-html",
      "readableView": "review-summary.html",
      "sourceArtifacts": ["review-summary.json"],
      "sourceSchemas": ["cautilus.review_summary.v1"],
      "renderer": "internal/runtime/review_html.go",
      "tests": ["internal/runtime/review_html_test.go"],
      "commands": ["cautilus review render-variants-summary-html"],
      "proofMarkers": [
        {"path": "internal/runtime/review_html.go", "contains": ["RenderReviewSummaryHTMLFromFile", "contracts.ReviewSummarySchema", "Generated from <code>review-summary.json</code>"]},
        {"path": "internal/runtime/review_html_test.go", "contains": ["TestRenderReviewSummaryHTMLFromFileRejectsWrongSchema", "TestWriteReviewSummaryHTMLFromFileWritesNextToInput"]}
      ]
    },
    {
      "id": "compare-html",
      "readableView": "compare.html",
      "sourceArtifacts": ["compare-artifact.json"],
      "sourceSchemas": ["cautilus.compare_artifact.v1"],
      "renderer": "internal/runtime/artifact_html.go",
      "tests": ["internal/runtime/artifact_html_test.go"],
      "commands": ["cautilus workspace render-compare-html"],
      "proofMarkers": [
        {"path": "internal/runtime/artifact_html.go", "contains": ["RenderCompareArtifactHTMLFromFile", "contracts.CompareArtifactSchema", "Generated from <code>compare-artifact.json</code>"]},
        {"path": "internal/runtime/artifact_html_test.go", "contains": ["TestRenderCompareArtifactHTMLFromFileRejectsWrongSchema", "TestWriteCompareArtifactHTMLFromFileWritesNextToInput"]}
      ]
    },
    {
      "id": "scenario-proposals-html",
      "readableView": "proposals.html",
      "sourceArtifacts": ["proposals.json"],
      "sourceSchemas": ["cautilus.scenario_proposals.v1"],
      "renderer": "internal/runtime/artifact_html.go",
      "tests": ["internal/runtime/artifact_html_test.go"],
      "commands": ["cautilus scenario render-proposals-html"],
      "proofMarkers": [
        {"path": "internal/runtime/artifact_html.go", "contains": ["RenderScenarioProposalsHTMLFromFile", "contracts.ScenarioProposalsSchema", "Generated from <code>proposals.json</code>"]},
        {"path": "internal/runtime/artifact_html_test.go", "contains": ["TestRenderScenarioProposalsHTMLFromFileRejectsWrongSchema", "TestWriteScenarioProposalsHTMLFromFileWritesNextToInput"]}
      ]
    },
    {
      "id": "scenario-conversation-review-html",
      "readableView": "conversation-review.html",
      "sourceArtifacts": ["conversation-review.json"],
      "sourceSchemas": ["cautilus.scenario_conversation_review.v1"],
      "renderer": "internal/runtime/artifact_html.go",
      "tests": ["internal/runtime/artifact_html_test.go"],
      "commands": ["cautilus scenario render-conversation-review-html"],
      "proofMarkers": [
        {"path": "internal/runtime/artifact_html.go", "contains": ["RenderScenarioConversationReviewHTMLFromFile", "contracts.ScenarioConversationReviewSchema", "Generated from <code>conversation-review.json</code>"]},
        {"path": "internal/runtime/artifact_html_test.go", "contains": ["TestRenderScenarioConversationReviewHTMLFromFileRejectsWrongSchema", "TestWriteScenarioConversationReviewHTMLFromFileWritesNextToInput"]}
      ]
    },
    {
      "id": "evidence-bundle-html",
      "readableView": "evidence-bundle.html",
      "sourceArtifacts": ["evidence-bundle.json"],
      "sourceSchemas": ["cautilus.evidence_bundle.v1"],
      "renderer": "internal/runtime/artifact_html.go",
      "tests": ["internal/runtime/artifact_html_test.go"],
      "commands": ["cautilus evidence render-html"],
      "proofMarkers": [
        {"path": "internal/runtime/artifact_html.go", "contains": ["RenderEvidenceBundleHTMLFromFile", "contracts.EvidenceBundleSchema", "Generated from <code>evidence-bundle.json</code>"]},
        {"path": "internal/runtime/artifact_html_test.go", "contains": ["TestRenderEvidenceBundleHTMLFromFileRejectsWrongSchema", "TestRenderEvidenceBundleHTMLRendersSignalsAndSources"]}
      ]
    },
    {
      "id": "run-index-html",
      "readableView": "index.html",
      "sourceArtifacts": ["known artifact packets in a run directory"],
      "sourceSchemas": ["run-index descriptor schemas"],
      "renderer": "internal/runtime/run_index_html.go",
      "tests": ["internal/runtime/run_index_html_test.go"],
      "commands": ["cautilus artifacts render-index-html"],
      "proofMarkers": [
        {"path": "internal/runtime/run_index_html.go", "contains": ["runIndexArtifactDescriptors", "descriptor.schema", "pending-html"]},
        {"path": "internal/runtime/run_index_html_test.go", "contains": ["TestDiscoverRunIndexEntriesSkipsMismatchedSchema", "TestRenderRunIndexHTMLIncludesSidebarEntriesAndStatus", "TestWriteRunIndexHTMLForDirWritesIndexHTML"]}
      ]
    },
    {
      "id": "self-dogfood-html",
      "readableView": "index.html",
      "sourceArtifacts": ["summary.json", "report.json", "review-summary.json"],
      "sourceSchemas": ["self-dogfood summary", "cautilus.report_packet.v2", "cautilus.review_summary.v1"],
      "renderer": "internal/runtime/self_dogfood_html.go",
      "tests": ["internal/runtime/self_dogfood_html_test.go"],
      "commands": ["cautilus self-dogfood render-html"],
      "proofMarkers": [
        {"path": "internal/runtime/self_dogfood_html.go", "contains": ["Generated from <code>summary.json</code>, <code>report.json</code>, and <code>review-summary.json</code>", "Do not hand-edit this file"]},
        {"path": "internal/runtime/self_dogfood_html_test.go", "contains": ["TestWriteSelfDogfoodHTMLWritesIndexNextToLatestBundle", "TestRenderSelfDogfoodHTMLRewritesMarkdownAndJSONLinks"]}
      ]
    },
    {
      "id": "self-dogfood-experiments-html",
      "readableView": "index.html",
      "sourceArtifacts": ["summary.json", "report.json"],
      "sourceSchemas": ["self-dogfood experiments summary", "cautilus.report_packet.v2"],
      "renderer": "internal/runtime/self_dogfood_html.go",
      "tests": ["internal/runtime/self_dogfood_html_test.go"],
      "commands": ["cautilus self-dogfood render-experiments-html"],
      "proofMarkers": [
        {"path": "internal/runtime/self_dogfood_html.go", "contains": ["Generated from <code>summary.json</code> and <code>report.json</code>", "Do not hand-edit this file"]},
        {"path": "internal/runtime/self_dogfood_html_test.go", "contains": ["TestWriteSelfDogfoodExperimentsHTMLWritesIndexNextToLatestBundle", "TestRenderSelfDogfoodExperimentsHTMLLinksInspectArtifactsWithoutRewritingRawJSON"]}
      ]
    },
    {
      "id": "review-prompt-markdown",
      "readableView": "review.prompt.md",
      "sourceArtifacts": ["review-prompt-input.json"],
      "sourceSchemas": ["cautilus.review_prompt_inputs.v1"],
      "renderer": "internal/runtime/review.go",
      "tests": ["internal/app/cli_smoke_test.go", "scripts/agent-runtime/review-prompt-flow.test.mjs"],
      "commands": ["cautilus review render-prompt"],
      "proofMarkers": [
        {"path": "internal/runtime/review.go", "contains": ["RenderReviewPrompt", "promptInput", "# Cautilus Review"]},
        {"path": "internal/app/cli_smoke_test.go", "contains": ["review", "render-prompt", "review.prompt.md"]},
        {"path": "scripts/agent-runtime/review-prompt-flow.test.mjs", "contains": ["renderReviewPrompt turns review prompt inputs into a portable meta-prompt", "## Current Report Evidence"]}
      ]
    },
    {
      "id": "claim-status-markdown",
      "readableView": "claim-status-report.md",
      "sourceArtifacts": ["claim proof plan", "claim status summary", "review results", "validation reports", "eval plans", "refresh plans", "canonical claim map"],
      "sourceSchemas": ["cautilus.claim_proof_plan.v1", "cautilus.claim_status_summary.v1"],
      "renderer": "scripts/agent-runtime/render-claim-status-report.mjs",
      "tests": ["scripts/agent-runtime/render-claim-status-report.test.mjs"],
      "commands": ["npm run claims:status-report"],
      "proofMarkers": [
        {"path": "scripts/agent-runtime/render-claim-status-report.mjs", "contains": ["Use the JSON packets as the audit source", "Active updates still match the current claim packet"]},
        {"path": "scripts/agent-runtime/render-claim-status-report.test.mjs", "contains": ["human-readable projection over the current claim packet", "Old proof gap should not appear as current work"]}
      ]
    },
    {
      "id": "claim-discovery-review-markdown",
      "readableView": "discovery-review.md",
      "sourceArtifacts": ["claim proof plan", "claim status summary"],
      "sourceSchemas": ["cautilus.claim_proof_plan.v1", "cautilus.claim_status_summary.v1"],
      "renderer": "scripts/agent-runtime/render-claim-discovery-review.mjs",
      "tests": ["scripts/agent-runtime/render-claim-discovery-review.test.mjs"],
      "commands": ["npm run claims:review-worksheet"],
      "proofMarkers": [
        {"path": "scripts/agent-runtime/render-claim-discovery-review.mjs", "contains": ["The JSON packet is the audit source", "renderReviewDocument"]},
        {"path": "scripts/agent-runtime/render-claim-discovery-review.test.mjs", "contains": ["creates a Markdown projection over claim packets", "The JSON packet is the audit source"]}
      ]
    },
    {
      "id": "claim-status-browser-review",
      "readableView": "Cautilus Review Decisions page",
      "sourceArtifacts": ["claim-status-report.md", "claim-status-comments.json"],
      "sourceSchemas": ["cautilus.claim_status_comments.v1"],
      "renderer": "scripts/agent-runtime/serve-claim-status-review.mjs",
      "tests": ["scripts/agent-runtime/serve-claim-status-review.test.mjs"],
      "commands": ["npm run claims:status-server"],
      "proofMarkers": [
        {"path": "scripts/agent-runtime/claim-status-review-page.mjs", "contains": ["Reference report details", "Save decisions"]},
        {"path": "scripts/agent-runtime/serve-claim-status-review.test.mjs", "contains": ["createReviewServer requires token and writes comment packet", "ignores saved comments from a stale report fingerprint"]}
      ]
    }
  ]
}
