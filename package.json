{
  "name": "cautilus",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "description": "Adapter-driven intentful behavior evaluation toolkit",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dogfood:self": "node scripts/run-self-dogfood.mjs",
    "dogfood:self:experiments": "node scripts/run-self-dogfood-experiments.mjs",
    "dogfood:self:html": "./bin/cautilus self-dogfood render-html",
    "dogfood:self:experiments:html": "./bin/cautilus self-dogfood render-experiments-html",
    "skills:sync-packaged": "node scripts/release/sync-packaged-skill.mjs",
    "release:prepare": "npm run skills:sync-packaged && node scripts/release/bump-version.mjs",
    "hooks:install": "node scripts/install-git-hooks.mjs",
    "hooks:check": "node scripts/check-git-hooks.mjs",
    "lint": "npm run lint:eslint && npm run lint:specs && npm run lint:go && npm run vet:go && npm run security:govulncheck",
    "lint:eslint": "eslint .",
    "lint:go": "node scripts/run-golangci-lint.mjs run ./cmd/... ./internal/...",
    "lint:specs": "node scripts/check-specs.mjs",
    "security:govulncheck": "node scripts/run-govulncheck.mjs ./...",
    "test:go": "go test ./cmd/... ./internal/...",
    "test:go:race": "go test -race ./cmd/... ./internal/...",
    "test:node": "node --test bin/*.test.mjs scripts/*.test.mjs scripts/agent-runtime/*.test.mjs scripts/release/*.test.mjs",
    "test:node:on-demand": "node --test scripts/on-demand/*.test.mjs",
    "test": "npm run test:go && npm run test:node",
    "test:on-demand": "npm run test:node:on-demand",
    "verify": "npm run lint && npm run test:go:race && npm run test:node",
    "vet:go": "go vet ./cmd/... ./internal/..."
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "eslint": "^9.24.0",
    "eslint-plugin-sonarjs": "^4.0.2"
  }
}
