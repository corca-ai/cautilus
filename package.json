{
  "name": "cautilus",
  "private": true,
  "version": "0.13.0",
  "type": "module",
  "description": "Adapter-driven intentful behavior evaluation toolkit",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dogfood:self": "npm run dogfood:self:eval",
    "dogfood:self:eval": "./bin/cautilus eval test --repo-root . --adapter-name self-dogfood-eval --output-dir ./artifacts/self-dogfood/eval/latest",
    "dogfood:app-chat:fixture": "./bin/cautilus eval test --repo-root . --adapter-name self-dogfood-app-chat --output-dir ./artifacts/self-dogfood/app-chat-fixture/latest",
    "dogfood:app-chat:codex": "./bin/cautilus eval test --repo-root . --adapter-name self-dogfood-app-chat --runtime codex --output-dir ./artifacts/self-dogfood/app-chat-codex/latest",
    "dogfood:app-chat:claude": "./bin/cautilus eval test --repo-root . --adapter-name self-dogfood-app-chat --runtime claude --output-dir ./artifacts/self-dogfood/app-chat-claude/latest",
    "dogfood:app-prompt:fixture": "./bin/cautilus eval test --repo-root . --adapter-name self-dogfood-app-prompt --output-dir ./artifacts/self-dogfood/app-prompt-fixture/latest",
    "dogfood:app-prompt:codex": "./bin/cautilus eval test --repo-root . --adapter-name self-dogfood-app-prompt --runtime codex --output-dir ./artifacts/self-dogfood/app-prompt-codex/latest",
    "dogfood:app-prompt:claude": "./bin/cautilus eval test --repo-root . --adapter-name self-dogfood-app-prompt --runtime claude --output-dir ./artifacts/self-dogfood/app-prompt-claude/latest",
    "dogfood:cautilus-refresh-flow": "node scripts/agent-runtime/run-cautilus-refresh-flow-dogfood.mjs --repo-root . --output-dir ./artifacts/self-dogfood/cautilus-refresh-flow/latest",
    "dogfood:cautilus-refresh-flow:eval": "./bin/cautilus eval test --repo-root . --adapter-name self-dogfood-refresh-flow --output-dir ./artifacts/self-dogfood/cautilus-refresh-flow-eval/latest",
    "dogfood:cautilus-refresh-flow:eval:codex": "./bin/cautilus eval test --repo-root . --adapter-name self-dogfood-refresh-flow --runtime codex --output-dir ./artifacts/self-dogfood/cautilus-refresh-flow-eval-codex/latest",
    "dogfood:cautilus-refresh-flow:eval:claude": "./bin/cautilus eval test --repo-root . --adapter-name self-dogfood-refresh-flow --runtime claude --output-dir ./artifacts/self-dogfood/cautilus-refresh-flow-eval-claude/latest",
    "dogfood:cautilus-first-scan-flow:eval:codex": "./bin/cautilus eval test --repo-root . --adapter-name self-dogfood-first-scan-flow --runtime codex --output-dir ./artifacts/self-dogfood/cautilus-first-scan-flow-eval-codex/latest",
    "dogfood:cautilus-first-scan-flow:eval:claude": "./bin/cautilus eval test --repo-root . --adapter-name self-dogfood-first-scan-flow --runtime claude --output-dir ./artifacts/self-dogfood/cautilus-first-scan-flow-eval-claude/latest",
    "dogfood:cautilus-review-prepare-flow:eval:codex": "./bin/cautilus eval test --repo-root . --adapter-name self-dogfood-review-prepare-flow --runtime codex --output-dir ./artifacts/self-dogfood/cautilus-review-prepare-flow-eval-codex/latest",
    "dogfood:cautilus-review-prepare-flow:eval:claude": "./bin/cautilus eval test --repo-root . --adapter-name self-dogfood-review-prepare-flow --runtime claude --output-dir ./artifacts/self-dogfood/cautilus-review-prepare-flow-eval-claude/latest",
    "dogfood:cautilus-reviewer-launch-flow:eval:codex": "./bin/cautilus eval test --repo-root . --adapter-name self-dogfood-reviewer-launch-flow --runtime codex --output-dir ./artifacts/self-dogfood/cautilus-reviewer-launch-flow-eval-codex/latest",
    "dogfood:cautilus-reviewer-launch-flow:eval:claude": "./bin/cautilus eval test --repo-root . --adapter-name self-dogfood-reviewer-launch-flow --runtime claude --output-dir ./artifacts/self-dogfood/cautilus-reviewer-launch-flow-eval-claude/latest",
    "dogfood:cautilus-review-to-eval-flow:eval:codex": "./bin/cautilus eval test --repo-root . --adapter-name self-dogfood-review-to-eval-flow --runtime codex --output-dir ./artifacts/self-dogfood/cautilus-review-to-eval-flow-eval-codex/latest",
    "dogfood:cautilus-review-to-eval-flow:eval:claude": "./bin/cautilus eval test --repo-root . --adapter-name self-dogfood-review-to-eval-flow --runtime claude --output-dir ./artifacts/self-dogfood/cautilus-review-to-eval-flow-eval-claude/latest",
    "dogfood:cautilus-packet-first-flow:eval:codex": "./bin/cautilus eval test --repo-root . --adapter-name self-dogfood-packet-first-flow --runtime codex --output-dir ./artifacts/self-dogfood/cautilus-packet-first-flow-eval-codex/latest",
    "dogfood:cautilus-packet-first-flow:eval:claude": "./bin/cautilus eval test --repo-root . --adapter-name self-dogfood-packet-first-flow --runtime claude --output-dir ./artifacts/self-dogfood/cautilus-packet-first-flow-eval-claude/latest",
    "dogfood:cautilus-canonical-spec-curation-flow:eval:codex": "./bin/cautilus eval test --repo-root . --adapter-name self-dogfood-canonical-spec-curation-flow --runtime codex --output-dir ./artifacts/self-dogfood/cautilus-canonical-spec-curation-flow-eval-codex/latest",
    "dogfood:cautilus-canonical-spec-curation-flow:eval:claude": "./bin/cautilus eval test --repo-root . --adapter-name self-dogfood-canonical-spec-curation-flow --runtime claude --output-dir ./artifacts/self-dogfood/cautilus-canonical-spec-curation-flow-eval-claude/latest",
    "dogfood:self:html": "./bin/cautilus self-dogfood render-html",
    "consumer:onboard:smoke": "node scripts/on-demand/smoke-external-consumer.mjs",
    "skills:sync-packaged": "node scripts/release/sync-packaged-skill.mjs",
    "release:prepare": "npm run skills:sync-packaged && node scripts/release/bump-version.mjs",
    "release:publish": "node scripts/release/publish-release.mjs",
    "release:smoke-install": "node scripts/release/run-install-smoke.mjs",
    "consumer:starters:smoke": "node scripts/on-demand/smoke-starter-kits.mjs",
    "hooks:install": "node scripts/install-git-hooks.mjs",
    "hooks:check": "node scripts/check-git-hooks.mjs",
    "docs:preview": "node scripts/preview-markdown.mjs",
    "docs:preview:changed": "node scripts/preview-markdown.mjs --changed",
    "docs:preview:specs": "node scripts/preview-markdown.mjs --specs",
    "lint": "npm run lint:eslint && npm run lint:specs && npm run lint:scenario-normalizers && npm run lint:contracts && npm run lint:links && npm run lint:skill-disclosure && npm run lint:go && npm run vet:go && npm run security:govulncheck && npm run security:secrets",
    "lint:scenario-normalizers": "node scripts/check-scenario-normalization-completeness.mjs",
    "lint:contracts": "node scripts/check-placeholder-drift.mjs && node scripts/check-proof-boundary-names.mjs",
    "lint:eslint": "eslint .",
    "lint:go": "node scripts/run-golangci-lint.mjs run ./cmd/... ./internal/...",
    "lint:links": "node scripts/check-markdown-links.mjs",
    "lint:skill-disclosure": "node scripts/check-cautilus-skill-disclosure.mjs",
    "lint:specs": "node scripts/check-specs.mjs && specdown run -quiet",
    "specdown": "specdown run",
    "specdown:pages": "npm run lint:specs && node scripts/prepare-specdown-pages.mjs",
    "security:govulncheck": "node scripts/run-govulncheck.mjs ./...",
    "security:secrets": "gitleaks detect --source . --no-banner --redact",
    "test:go": "go test ./cmd/... ./internal/...",
    "test:go:race": "go test -race ./cmd/... ./internal/...",
    "test:go:coverage": "mkdir -p coverage && go test -covermode=atomic -coverprofile=coverage/go.out ./internal/... && node scripts/summarize-go-coverage.mjs",
    "test:node": "node --test --test-reporter=dot --test-reporter-destination=stdout bin/*.test.mjs scripts/*.test.mjs scripts/agent-runtime/*.test.mjs scripts/release/*.test.mjs",
    "test:node:spec": "node --test --test-reporter=spec --test-reporter-destination=stdout bin/*.test.mjs scripts/*.test.mjs scripts/agent-runtime/*.test.mjs scripts/release/*.test.mjs",
    "test:node:on-demand": "node --test --test-reporter=dot --test-reporter-destination=stdout scripts/on-demand/*.test.mjs",
    "audit:no-input-log": "node scripts/agent-runtime/audit-cautilus-no-input-log.mjs",
    "audit:refresh-flow-log": "node scripts/agent-runtime/audit-cautilus-refresh-flow-log.mjs",
    "audit:first-scan-flow-log": "node scripts/agent-runtime/audit-cautilus-first-scan-flow-log.mjs",
    "audit:review-prepare-flow-log": "node scripts/agent-runtime/audit-cautilus-review-prepare-flow-log.mjs",
    "audit:reviewer-launch-flow-log": "node scripts/agent-runtime/audit-cautilus-reviewer-launch-flow-log.mjs",
    "audit:review-to-eval-flow-log": "node scripts/agent-runtime/audit-cautilus-review-to-eval-flow-log.mjs",
    "audit:canonical-spec-curation-flow-log": "node scripts/agent-runtime/audit-cautilus-canonical-spec-curation-flow-log.mjs",
    "claims:apply-review-results": "node scripts/agent-runtime/apply-current-review-results.mjs --claims .cautilus/claims/latest.json --claims-dir .cautilus/claims --output .cautilus/claims/evidenced-typed-runners.json",
    "claims:audit-evidence": "node scripts/agent-runtime/audit-claim-evidence-hashes.mjs --repo-root . --claims-dir .cautilus/claims --summary",
    "claims:canonical-map": "node scripts/agent-runtime/build-canonical-claim-map.mjs --claims .cautilus/claims/evidenced-typed-runners.json --output .cautilus/claims/canonical-claim-map.json",
    "claims:review-input-summary": "node scripts/agent-runtime/render-claim-review-input-summary.mjs",
    "claims:review-worksheet": "node scripts/agent-runtime/render-claim-discovery-review.mjs --claims .cautilus/claims/evidenced-typed-runners.json --status .cautilus/claims/status-summary.json --output .cautilus/claims/discovery-review.md",
    "claims:status-report": "node scripts/agent-runtime/render-claim-status-report.mjs --claims .cautilus/claims/evidenced-typed-runners.json --status .cautilus/claims/status-summary.json --output .cautilus/claims/claim-status-report.md",
    "claims:status-server": "node scripts/agent-runtime/serve-claim-status-review.mjs",
    "test:node:coverage": "c8 --reporter=lcov --reports-dir=coverage --include='scripts/**' --include='bin/**' --exclude='**/*.test.mjs' --exclude='scripts/on-demand/**' node --test bin/*.test.mjs scripts/*.test.mjs scripts/agent-runtime/*.test.mjs scripts/release/*.test.mjs && node scripts/summarize-node-coverage.mjs",
    "test:coverage": "npm run test:go:coverage && npm run test:node:coverage && node scripts/aggregate-coverage.mjs",
    "coverage:floor:check": "./scripts/coverage-floor-quality-gate.sh",
    "coverage:floor:write": "node scripts/write-coverage-floor.mjs",
    "test": "npm run test:go && npm run test:node",
    "test:on-demand": "npm run test:node:on-demand",
    "verify": "node scripts/run-verify.mjs",
    "verify:verbose": "node scripts/run-verify.mjs --verbose",
    "vet:go": "go vet ./cmd/... ./internal/...",
    "session:summarize": "node scripts/agent-runtime/summarize-codex-session-log.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "c8": "^11.0.0",
    "eslint": "^9.24.0",
    "eslint-plugin-sonarjs": "^4.0.2"
  }
}
