    "dogfood:self:experiments:html": "./bin/cautilus self-dogfood render-experiments-html",
    "consumer:onboard:smoke": "node scripts/on-demand/smoke-external-consumer.mjs",
    "skills:sync-packaged": "node scripts/release/sync-packaged-skill.mjs",
    "release:prepare": "npm run skills:sync-packaged && node scripts/release/bump-version.mjs",
    "release:verify-public": "node scripts/release/verify-public-release.mjs",
    "release:smoke-install": "node scripts/release/run-install-smoke.mjs",
    "release:smoke-install:brew": "node scripts/release/run-install-smoke.mjs --channel homebrew --allow-system-mutation",
    "hooks:install": "node scripts/install-git-hooks.mjs",
    "hooks:check": "node scripts/check-git-hooks.mjs",
    "docs:preview": "node scripts/preview-markdown.mjs",
    "docs:preview:changed": "node scripts/preview-markdown.mjs --changed",
    "docs:preview:specs": "node scripts/preview-markdown.mjs --specs",
    "lint": "npm run lint:eslint && npm run lint:specs && npm run lint:archetypes && npm run lint:contracts && npm run lint:links && npm run lint:go && npm run vet:go && npm run security:govulncheck",
    "lint:archetypes": "node scripts/check-archetype-completeness.mjs",
    "lint:contracts": "node scripts/check-placeholder-drift.mjs",
    "lint:eslint": "eslint .",
    "lint:go": "node scripts/run-golangci-lint.mjs run ./cmd/... ./internal/...",
    "lint:links": "node scripts/check-markdown-links.mjs",
    "lint:specs": "node scripts/check-specs.mjs && specdown run -quiet",
    "specdown": "specdown run",
    "specdown:pages": "npm run lint:specs && node scripts/prepare-specdown-pages.mjs",
    "security:govulncheck": "node scripts/run-govulncheck.mjs ./...",
    "test:go": "go test ./cmd/... ./internal/...",
    "test:go:race": "go test -race ./cmd/... ./internal/...",
    "test:node": "node --test --test-reporter=dot --test-reporter-destination=stdout bin/*.test.mjs scripts/*.test.mjs scripts/agent-runtime/*.test.mjs scripts/release/*.test.mjs",
    "test:node:spec": "node --test --test-reporter=spec --test-reporter-destination=stdout bin/*.test.mjs scripts/*.test.mjs scripts/agent-runtime/*.test.mjs scripts/release/*.test.mjs",
    "test:node:on-demand": "node --test --test-reporter=dot --test-reporter-destination=stdout scripts/on-demand/*.test.mjs",
    "test": "npm run test:go && npm run test:node",
    "test:on-demand": "npm run test:node:on-demand",
    "verify": "node scripts/run-verify.mjs",
    "verify:verbose": "node scripts/run-verify.mjs --verbose",
    "vet:go": "go vet ./cmd/... ./internal/..."
  },
  "devDependencies": {
