version: 1
repo: cautilus
evaluation_surfaces:
  - local bundled cautilus skill can orchestrate a checked-in skill test request
baseline_options:
  - baseline git ref in the same repo via {baseline_ref}
required_prerequisites:
  - materialize the local cautilus skill surface before running nested skill tests
preflight_commands:
  - ./bin/cautilus install --repo-root . --overwrite
  - ./bin/cautilus doctor --repo-root . --scope agent-surface
skill_cases_default: fixtures/skill-test/cases.json
skill_test_command_templates:
